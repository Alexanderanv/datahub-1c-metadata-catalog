# Настройки демонстрационного контура.
#
# Скопируйте файл в deploy/reference/.env и заполните локальные значения.
# Не коммитьте заполненный .env файл.

# Backend DataHub. Если runner загрузки запущен в Docker, а DataHub работает
# на хостовой машине, в Docker Desktop обычно подходит host.docker.internal.
DATAHUB_GMS_URL=http://host.docker.internal:8080
# Опциональный bearer token для DataHub GMS с авторизацией.
DATAHUB_GMS_TOKEN=

# Сервис метаданных 1С.
ONEC_BASE_URL=http://1c-host/1c-test/hs/metadataservice
ONEC_USERNAME=Администратор
ONEC_PASSWORD=

# Стабильный технический идентификатор информационной базы и отображаемое имя
# в навигации DataHub.
ONEC_INFOBASE_NAME=1c-test
ONEC_INFOBASE_DISPLAY_NAME=1c-test

# ConfigDumpInfo.xml должен быть смонтирован в runner загрузки по этому пути.
ONEC_CONFIG_DUMP_INFO_PATH=/configdump/ConfigDumpInfo.xml
CONFIGDUMP_VALIDATE_SCOPE=true
CONFIGDUMP_MAX_AGE_SECONDS=

# Для кастомных аспектов в DataHub GMS должна быть установлена кастомная
# метамодель.
ONEC_EMIT_CUSTOM_ASPECTS=true

# Настройки слоя базы данных. Сам коннектор не привязан к конкретной СУБД, но
# этот пример использует стандартный postgres source DataHub для физической
# базы 1С.
POSTGRES_INGEST_ENABLED=true
POSTGRES_DATABASE=1c-test
POSTGRES_SCHEMA=public
POSTGRES_HOST_PORT=1c-db:5432
POSTGRES_USERNAME=
POSTGRES_PASSWORD=

# Стандартные DataHub Siblings между datasets 1С и datasets физической базы.
ONEC_EMIT_DB_SIBLINGS=true

# Настройки образа опционального ConfigDumpInfo exporter.
ONEC_VERSION=8.3.27.1936
ONEC_CONFIGDUMP_IMAGE=ghcr.io/alexanderanv/onec-configdump-exporter:${ONEC_VERSION}

# Порт опционального MFE server.
ONEC_MFE_PORT=3002

# Подключение Designer для опционального ConfigDumpInfo exporter.
# Это не URL HTTP-сервиса. ONEC_INFOBASE - Ref информационной базы сервера 1С
# для Designer (/S). Он может отличаться от ONEC_INFOBASE_NAME, который
# используется в DataHub URN.
ONEC_SERVER=1c-host
ONEC_INFOBASE=1c-test
# ONEC_IB_CONNECTION=Srvr="1c-host";Ref="1c-test";
# ONEC_FILE_DB=/work/ib
ONEC_OUTPUT_DIR=/out
ONEC_RESULT_FILE=/out/ConfigDumpInfo.xml
ONEC_WORK_DIR=/work
ONEC_DUMP_DIR=/work/config-dump
ONEC_LOG_FILE=/out/configdump-export.log
ONEC_FORMAT=Hierarchical
ONEC_USE_XVFB=auto
