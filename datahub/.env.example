# Скопируй в .env и заполни значениями:
#   cp .env.example .env
#
# Файл .env НЕ коммитится (см. .gitignore) — он содержит пароль.

# --- 1С: Metadata Service --------------------------------------------------
ONEC_BASE_URL=http://1c-host/1c-test/hs/metadataservice
ONEC_USERNAME=Администратор
ONEC_PASSWORD=

# Технический идентификатор ИБ используется в 1С dataset/container URN и в
# browse hierarchy, чтобы несколько ИБ не смешивались в DataHub.
# Display name — только человекочитаемая подпись в UI.
ONEC_INFOBASE_NAME=1c-test
ONEC_INFOBASE_DISPLAY_NAME=1c-test

# Путь к ConfigDumpInfo.xml — выгрузка стабильных UUID объектов метаданных
# из 1С. URN dataset/container 1С строятся не из имени, а из этих UUID, чтобы
# переименование объекта в 1С не ломало историю и связи в DataHub.
# Файл нужно выгрузить из той же конфигурации 1С, которую читает Metadata
# Service. Для автоматической выгрузки см. 1c-metadata-service/configdump-exporter.
ONEC_CONFIG_DUMP_INFO_PATH=/path/to/ConfigDumpInfo.xml

# После установки custom-models в GMS custom aspects включены.
# Для временного запуска против чистого OSS-GMS можно поставить false.
ONEC_EMIT_CUSTOM_ASPECTS=true

# --- DataHub GMS -----------------------------------------------------------
DATAHUB_GMS_URL=http://localhost:8080
# Если GMS защищён токеном, укажи его здесь. Для локального OSS quickstart
# обычно не нужен.
DATAHUB_GMS_TOKEN=

# --- Физическая база данных -----------------------------------------------
# Команда `make demo.ingest` запускает reference ingest: сначала 1С, затем
# опционально стандартный database ingest, чтобы логический слой 1С и
# физический слой базы данных оставались согласованы. Для окружений без доступа
# к реальной базе можно поставить false; тогда будут эмититься только DB-скелеты
# из 1С `/db-mapping`.
POSTGRES_INGEST_ENABLED=true

# Стандартный Siblings aspect между 1С-датасетами и DB-датасетами.
# true включает sibling-switcher в стандартном DataHub UI.
# false оставляет oneCDbMapping/MapsToDbTable, но не эмитит standard Siblings.
# Уже записанные Siblings не очищаются автоматически; для существующего
# каталога нужен reload from zero или отдельная миграция.
ONEC_EMIT_DB_SIBLINGS=true

# Параметры нужны recipe `examples/recipes/1c-full.dhub.yaml` (1С эмитит DB
# datasets без реальных типов — «скелет»), а также recipe
# `examples/recipes/db-postgres.dhub.yaml` (стандартный database-коннектор
# DataHub дотягивает реальные типы и статистики на тех же URN).
#
# POSTGRES_DATABASE / POSTGRES_SCHEMA входят в URN DB-датасетов как
# `<database>.<schema>.<table>` — формат совпадает со стандартным
# DataHub database-коннектором, поэтому optional Siblings сматчатся по URN.
# Явное значение нужно, когда физическая DB называется иначе, чем
# информационная база.

POSTGRES_DATABASE=1c-test
POSTGRES_SCHEMA=public

# Подключение к реальной PostgreSQL-базе для examples/recipes/db-postgres.dhub.yaml.
# Если реальной БД пока нет — эти переменные можно оставить пустыми:
# zakaz-klienta recipe работает без них (скелет строится из /db-mapping).
POSTGRES_HOST_PORT=1c-db:5432
POSTGRES_USERNAME=
POSTGRES_PASSWORD=
