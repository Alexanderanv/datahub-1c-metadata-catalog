# Copy to .env and fill local values. This file intentionally uses a different
# shape than datahub/.env because the exporter connects to 1C Designer, not to
# the HTTP metadata service.

# Server infobase mode. ONEC_INFOBASE must be the 1C server infobase
# reference name used by Designer (/S), not necessarily the HTTP publication
# path from http://host/<publication>/hs/...
ONEC_SERVER=1c-host
ONEC_INFOBASE=1c-test

# Alternative 1: file infobase mode.
# ONEC_FILE_DB=/work/ib

# Alternative 2: full 1C connection string. Use this when the Designer
# connection needs an explicit cluster address, port, or non-publication Ref.
# ONEC_IB_CONNECTION=Srvr="1c-host";Ref="1c-test";

ONEC_USERNAME=Администратор
ONEC_PASSWORD=

ONEC_OUTPUT_DIR=/out
ONEC_RESULT_FILE=/out/ConfigDumpInfo.xml
ONEC_WORK_DIR=/work
ONEC_DUMP_DIR=/work/config-dump
ONEC_LOG_FILE=/out/configdump-export.log
ONEC_FORMAT=Hierarchical

# auto: use xvfb-run when DISPLAY is absent; always: force xvfb-run; never: run directly.
ONEC_USE_XVFB=auto
