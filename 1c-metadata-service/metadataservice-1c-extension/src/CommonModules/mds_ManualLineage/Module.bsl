// Создаёт структуру деталей для ручной lineage-связи.
//
// Возвращаемое значение:
//  Структура - JSON-совместимые детали правила.
Функция НовыеДеталиСвязи(
	Происхождение,
	ИдентификаторПравила = Неопределено,
	ДополнительныеДетали = Неопределено
) Экспорт

	Детали = Новый Структура;
	Детали.Вставить("origin", Происхождение);

	Если ИдентификаторПравила <> Неопределено Тогда
		Детали.Вставить("rule_id", ИдентификаторПравила);
	Иначе
		Детали.Вставить("rule_id", "");
	КонецЕсли;

	Если ДополнительныеДетали <> Неопределено Тогда
		Для Каждого ЭлементДеталей Из ДополнительныеДетали Цикл
			Детали.Вставить(ЭлементДеталей.Ключ, ЭлементДеталей.Значение);
		КонецЦикла;
	КонецЕсли;

	Возврат Детали;

КонецФункции

// Создаёт структуру ручной dataset-level lineage-связи.
//
// Возвращаемое значение:
//  Структура - описание ручной dataset-level lineage-связи.
Функция НоваяСвязьНаборовДанных(
	ОбъектИсточник,
	ОбъектПриемник,
	Описание = Неопределено,
	Уверенность = "high",
	Детали = Неопределено
) Экспорт

	Связь = Новый Структура;
	Связь.Вставить("ВидСвязи", "manual_dataset_flow");
	Связь.Вставить("ОбъектИсточник", ПолноеИмяОбъектаДляПравила(ОбъектИсточник));
	Связь.Вставить("ОбъектПриемник", ПолноеИмяОбъектаДляПравила(ОбъектПриемник));
	Связь.Вставить("ИсточникСвязи", "manual");
	Связь.Вставить("Уверенность", Уверенность);

	Если Описание <> Неопределено Тогда
		Связь.Вставить("Описание", Описание);
	Иначе
		Связь.Вставить("Описание", "");
	КонецЕсли;

	Если Детали <> Неопределено Тогда
		Связь.Вставить("Детали", Детали);
	Иначе
		Связь.Вставить("Детали", Новый Структура);
	КонецЕсли;

	Возврат Связь;

КонецФункции

// Добавляет в массив ручную dataset-level lineage-связь.
Процедура ДобавитьСвязьНаборовДанных(
	Связи,
	ОбъектИсточник,
	ОбъектПриемник,
	Описание = Неопределено,
	Уверенность = "high",
	Детали = Неопределено
) Экспорт

	Связи.Добавить(НоваяСвязьНаборовДанных(
		ОбъектИсточник,
		ОбъектПриемник,
		Описание,
		Уверенность,
		Детали
	));

КонецПроцедуры

// Создаёт описание входящией связи интеграционного сервиса.
//
// Возвращаемое значение:
//  Структура - описание входящией связи.
Функция НоваяВнутренняяСвязьИнтеграционногоСервиса(ПолноеИмяЭндпоинта,
	ОбъектИсточник,
	Описание = Неопределено,
	Уверенность = "high",
	Детали = Неопределено
) Экспорт

	Связь = Новый Структура;
	Связь.Вставить("ВидСвязи", "integration_service_input");
	Связь.Вставить("Эндпоинт", ПолноеИмяЭндпоинта);
	Связь.Вставить("ОбъектИсточник", ПолноеИмяОбъектаДляПравила(ОбъектИсточник));
	Связь.Вставить("ИсточникСвязи", "manual");
	Связь.Вставить("Уверенность", Уверенность);

	Если Описание <> Неопределено Тогда
		Связь.Вставить("Описание", Описание);
	Иначе
		Связь.Вставить("Описание", "");
	КонецЕсли;

	Если Детали <> Неопределено Тогда
		Связь.Вставить("Детали", Детали);
	Иначе
		Связь.Вставить("Детали", Новый Структура);
	КонецЕсли;

	Возврат Связь;

КонецФункции

// Добавляет входящие свзяи HTTP сервиса.
Процедура ДобавитьВходМетодаHTTPСервиса(
	Связи,
	ИмяСервиса,
	ИмяШаблонаURL,
	ИмяМетода,
	ОбъектИсточник,
	Описание = Неопределено,
	Уверенность = "high",
	Детали = Неопределено
) Экспорт

	ПолноеИмяЭндпоинта = "HTTPService." + ИмяСервиса
		+ ".URLTemplate." + ИмяШаблонаURL
		+ ".Method." + ИмяМетода;
	Связи.Добавить(НоваяВнутренняяСвязьИнтеграционногоСервиса(
		ПолноеИмяЭндпоинта,
		ОбъектИсточник,
		Описание,
		Уверенность,
		Детали
	));

КонецПроцедуры

// Добавляет входящие связи Web сервиса.
Процедура ДобавитьВходОперацииWebСервиса(
	Связи,
	ИмяСервиса,
	ИмяОперации,
	ОбъектИсточник,
	Описание = Неопределено,
	Уверенность = "high",
	Детали = Неопределено
) Экспорт

	ПолноеИмяЭндпоинта = "WebService." + ИмяСервиса
		+ ".Operation." + ИмяОперации;
	Связи.Добавить(НоваяВнутренняяСвязьИнтеграционногоСервиса(
		ПолноеИмяЭндпоинта,
		ОбъектИсточник,
		Описание,
		Уверенность,
		Детали
	));

КонецПроцедуры

Функция ПолноеИмяОбъектаДляПравила(ОбъектИсточник)
	Если ОбъектИсточник = Неопределено Тогда
		Возврат "";
	КонецЕсли;

	Если ТипЗнч(ОбъектИсточник) = Тип("Строка") Тогда
		Возврат ОбъектИсточник;
	КонецЕсли;

	Попытка
		Возврат ОбъектИсточник.ПолноеИмя();
	Исключение
		Возврат Строка(ОбъектИсточник);
	КонецПопытки;
КонецФункции

// Вызывает дополнение связей в менеджере объекта.
Процедура ВызватьДополнениеLineageМенеджера(Связи, Контекст, ОбъектМД) Экспорт

	Менеджер = МенеджерОбъектаМетаданных(ОбъектМД);
	Если Менеджер = Неопределено Тогда
		ВызватьИсключение "Для объекта метаданных не найден менеджер: " + ОбъектМД.ПолноеИмя();
	КонецЕсли;

	Менеджер.mds_ДополнитьLineageОбъекта(Связи, Контекст);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция МенеджерОбъектаМетаданных(ОбъектМД)

	ПолноеИмя = ОбъектМД.ПолноеИмя();
	Части = СтрРазделить(ПолноеИмя, ".");
	Если Части.Количество() < 2 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Вид = Части[0];
	Имя = Части[1];

	Если Вид = "Справочник" Или Вид = "Catalog" Тогда
		Возврат Справочники[Имя];
	ИначеЕсли Вид = "Документ" Или Вид = "Document" Тогда
		Возврат Документы[Имя];
	ИначеЕсли Вид = "ПланВидовХарактеристик" Или Вид = "ChartOfCharacteristicTypes" Тогда
		Возврат ПланыВидовХарактеристик[Имя];
	ИначеЕсли Вид = "ПланСчетов" Или Вид = "ChartOfAccounts" Тогда
		Возврат ПланыСчетов[Имя];
	ИначеЕсли Вид = "ПланВидовРасчета" Или Вид = "ChartOfCalculationTypes" Тогда
		Возврат ПланыВидовРасчета[Имя];
	ИначеЕсли Вид = "РегистрСведений" Или Вид = "InformationRegister" Тогда
		Возврат РегистрыСведений[Имя];
	ИначеЕсли Вид = "РегистрНакопления" Или Вид = "AccumulationRegister" Тогда
		Возврат РегистрыНакопления[Имя];
	ИначеЕсли Вид = "РегистрБухгалтерии" Или Вид = "AccountingRegister" Тогда
		Возврат РегистрыБухгалтерии[Имя];
	ИначеЕсли Вид = "РегистрРасчета" Или Вид = "CalculationRegister" Тогда
		Возврат РегистрыРасчета[Имя];
	ИначеЕсли Вид = "БизнесПроцесс" Или Вид = "BusinessProcess" Тогда
		Возврат БизнесПроцессы[Имя];
	ИначеЕсли Вид = "Задача" Или Вид = "Task" Тогда
		Возврат Задачи[Имя];
	ИначеЕсли Вид = "Отчет" Или Вид = "Report" Тогда
		Возврат Отчеты[Имя];
	ИначеЕсли Вид = "Обработка" Или Вид = "DataProcessor" Тогда
		Возврат Обработки[Имя];
	КонецЕсли;

	Возврат Неопределено;

КонецФункции

#КонецОбласти
