#Область ОбработчикиСобытий

Функция HealthGET(Запрос)
	Данные = Новый Структура;
	Данные.Вставить("status", "ok");
	Данные.Вставить("version", "1.0.0");
	Возврат ОтветJSON(200, Данные);
КонецФункции

Функция ObjectsGET(Запрос)
	Подпуть = ПодпутьПослеПрефикса(Запрос.ОтносительныйURL, "/objects");

	Если ПустаяСтрока(Подпуть) Тогда
		Возврат СписокОбъектов(Запрос);
	КонецЕсли;

	Сегменты = СтрРазделить(Подпуть, "/");

	Если Сегменты.Количество() = 2 Тогда
		Возврат ДеталиОбъекта(Сегменты[0], Сегменты[1]);
	ИначеЕсли Сегменты.Количество() = 3 И Сегменты[2] = "tabular-parts" Тогда
		Возврат ТабличныеЧастиОбъекта(Сегменты[0], Сегменты[1]);
	Иначе
		Возврат ОтветОшибки(404, "Unknown path");
	КонецЕсли;
КонецФункции

Функция ReferencesGET(Запрос)
	ФильтрТипов = Новый Массив;
	ТипыСтрока = Запрос.ПараметрыЗапроса.Получить("types");
	Если ТипыСтрока <> Неопределено И НЕ ПустаяСтрока(ТипыСтрока) Тогда
		Для Каждого ЭлементТипа Из СтрРазделить(ТипыСтрока, ",") Цикл
			ФильтрТипов.Добавить(СокрЛП(ЭлементТипа));
		КонецЦикла;
	КонецЕсли;

	ФильтрОбъектов = Новый Соответствие;
	ОбъектыСтрока = Запрос.ПараметрыЗапроса.Получить("objects");
	Если ОбъектыСтрока <> Неопределено И НЕ ПустаяСтрока(ОбъектыСтрока) Тогда
		Для Каждого ЭлементОбъекта Из СтрРазделить(ОбъектыСтрока, ",") Цикл
			ПолноеИмяОбъекта = КаноническоеПолноеИмяИзПолногоИмени(СокрЛП(ЭлементОбъекта));
			Если НЕ ПустаяСтрока(ПолноеИмяОбъекта) Тогда
				ФильтрОбъектов.Вставить(ПолноеИмяОбъекта, Истина);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	Уровень = Запрос.ПараметрыЗапроса.Получить("level");
	ДетальноКолонки = (Уровень <> Неопределено И Уровень = "columns");

	Результат = Новый Массив;
	ТипыОбъектов = ПоддерживаемыеТипыОбъектов();

	Для Каждого КлючЗначение Из ТипыОбъектов Цикл
		ИмяТипа = КлючЗначение.Ключ;
		КоллекцияМетаданных = КлючЗначение.Значение;

		Если ФильтрТипов.Количество() > 0 И ФильтрТипов.Найти(ИмяТипа) = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого ОбъектМД Из КоллекцияМетаданных Цикл
			Если НЕ ЭтоОбъектОсновнойКонфигурации(ОбъектМД) Тогда
				Продолжить;
			КонецЕсли;

			Если ФильтрОбъектов.Количество() > 0
				И ФильтрОбъектов.Получить(КаноническоеПолноеИмяОбъекта(ОбъектМД)) = Неопределено Тогда
				Продолжить;
			КонецЕсли;

			СобратьСсылкиОбъекта(Результат, ОбъектМД, ИмяТипа, ДетальноКолонки, ФильтрОбъектов);
		КонецЦикла;
	КонецЦикла;

	Если НЕ ДетальноКолонки Тогда
		Результат = ДедублироватьСсылки(Результат);
	КонецЕсли;
	Возврат ОтветJSON(200, Результат);
КонецФункции

Функция DbMappingGET(Запрос)
	Подпуть = ПодпутьПослеПрефикса(Запрос.ОтносительныйURL, "/db-mapping");

	Если ПустаяСтрока(Подпуть) Тогда
		// GET /db-mapping — список всех объектов
		Возврат СписокМаппингаБД(Запрос);
	КонецЕсли;

	Сегменты = СтрРазделить(Подпуть, "/");

	Если Сегменты.Количество() = 2 Тогда
		// GET /db-mapping/{type}/{name} — детальный маппинг
		Возврат МаппингОбъектаБД(Сегменты[0], Сегменты[1]);
	Иначе
		Возврат ОтветОшибки(404, "Unknown path");
	КонецЕсли;
КонецФункции

Функция LineageGET(Запрос)
	ФильтрОбъектов = ФильтрСпискаОбъектовПоПараметру(Запрос, "objects");
	ФильтрВидовСвязей = ФильтрСпискаПоПараметру(Запрос, "kinds");

	Результат = Новый Массив;

	СобратьLineageВводаНаОсновании(Результат, ФильтрОбъектов, ФильтрВидовСвязей);
	СобратьLineageДвиженийРегистров(Результат, ФильтрОбъектов, ФильтрВидовСвязей);
	СобратьLineageКритериевОтбора(Результат, ФильтрОбъектов, ФильтрВидовСвязей);
	СобратьLineageРучныхСвязей(Результат, ФильтрОбъектов, ФильтрВидовСвязей);

	Возврат ОтветJSON(200, ДедублироватьLineage(Результат));
КонецФункции

Функция IntegrationServicesGET(Запрос)
	ФильтрТипов = ФильтрСпискаПоПараметру(Запрос, "types");
	ФильтрСервисов = ФильтрСпискаОбъектовПоПараметру(Запрос, "services");
	ФильтрЭндпоинтов = ФильтрСпискаОбъектовПоПараметру(Запрос, "endpoints");
	ВнутренниеВходы = ВнутренниеВходыИнтеграционныхСервисов(
		ФильтрТипов,
		ФильтрСервисов,
		ФильтрЭндпоинтов
	);

	Результат = Новый Массив;

	Если ТипИнтеграционногоСервисаРазрешен(ФильтрТипов, "HTTPServices") Тогда
		СобратьHTTPСервисы(Результат, ФильтрСервисов, ФильтрЭндпоинтов, ВнутренниеВходы);
	КонецЕсли;

	Если ТипИнтеграционногоСервисаРазрешен(ФильтрТипов, "WebServices") Тогда
		СобратьWebСервисы(Результат, ФильтрСервисов, ФильтрЭндпоинтов, ВнутренниеВходы);
	КонецЕсли;

	ПроверитьВнутренниеВходыИнтеграционныхСервисов(ВнутренниеВходы, Результат);

	Возврат ОтветJSON(200, Результат);
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПолучениеСписковОбъектов

Функция СписокОбъектов(Запрос)
	ФильтрТипов = Новый Массив;
	ТипыСтрока = Запрос.ПараметрыЗапроса.Получить("types");
	Если ТипыСтрока <> Неопределено И НЕ ПустаяСтрока(ТипыСтрока) Тогда
		Для Каждого ЭлементТипа Из СтрРазделить(ТипыСтрока, ",") Цикл
			ФильтрТипов.Добавить(СокрЛП(ЭлементТипа));
		КонецЦикла;
	КонецЕсли;

	Результат = Новый Массив;
	ТипыОбъектов = ПоддерживаемыеТипыОбъектов();

	Для Каждого КлючЗначение Из ТипыОбъектов Цикл
		ИмяТипа = КлючЗначение.Ключ;
		КоллекцияМетаданных = КлючЗначение.Значение;

		Если ФильтрТипов.Количество() > 0 И ФильтрТипов.Найти(ИмяТипа) = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого ОбъектМД Из КоллекцияМетаданных Цикл
			Если НЕ ЭтоОбъектОсновнойКонфигурации(ОбъектМД) Тогда
				Продолжить;
			КонецЕсли;

			Синоним = ОбъектМД.Синоним;
			Если ПустаяСтрока(Синоним) Тогда
				Синоним = ОбъектМД.Имя;
			КонецЕсли;

			Описание = Новый Структура;
			Описание.Вставить("object_type", ИмяТипа);
			Описание.Вставить("name", ОбъектМД.Имя);
			Описание.Вставить("full_name", КаноническоеПолноеИмяОбъекта(ОбъектМД));
			Описание.Вставить("synonym", Синоним);
			Результат.Добавить(Описание);
		КонецЦикла;
	КонецЦикла;

	Возврат ОтветJSON(200, Результат);
КонецФункции

#КонецОбласти

#Область ДанныеОбъектов

Функция ДеталиОбъекта(ИмяТипа, ИмяОбъекта)
	ОбъектМД = НайтиОбъектМетаданных(ИмяТипа, ИмяОбъекта);
	Если ОбъектМД = Неопределено Тогда
		Возврат ОтветОшибки(404, "Object not found: " + ИмяТипа + "." + ИмяОбъекта);
	КонецЕсли;

	Синоним = ОбъектМД.Синоним;
	Если ПустаяСтрока(Синоним) Тогда
		Синоним = ОбъектМД.Имя;
	КонецЕсли;

	Результат = Новый Структура;
	Результат.Вставить("object_type", ИмяТипа);
	Результат.Вставить("name", ОбъектМД.Имя);
	Результат.Вставить("full_name", КаноническоеПолноеИмяОбъекта(ОбъектМД));
	Результат.Вставить("synonym", Синоним);

	Комментарий = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Комментарий");
	Если Комментарий <> Неопределено И НЕ ПустаяСтрока(Комментарий) Тогда
		Результат.Вставить("comment", Комментарий);
	КонецЕсли;

	Результат.Вставить("attributes", СобратьРеквизиты(ОбъектМД, ИмяТипа));

	// Видо-специфичные под-объекты (см. OpenAPI CatalogProperties / DocumentProperties / RegisterProperties).
	Если ИмяТипа = "Catalogs"
		ИЛИ ИмяТипа = "ChartsOfCharacteristicTypes"
		ИЛИ ИмяТипа = "ChartsOfAccounts"
		ИЛИ ИмяТипа = "ChartsOfCalculationTypes" Тогда
		СвойстваСправочника = СобратьСвойстваСправочника(ОбъектМД, ИмяТипа);
		Если СвойстваСправочника.Количество() > 0 Тогда
			Результат.Вставить("catalog_properties", СвойстваСправочника);
		КонецЕсли;
	ИначеЕсли ИмяТипа = "Documents" Тогда
		СвойстваДокумента = СобратьСвойстваДокумента(ОбъектМД);
		Если СвойстваДокумента.Количество() > 0 Тогда
			Результат.Вставить("document_properties", СвойстваДокумента);
		КонецЕсли;
	ИначеЕсли ЭтоРегистрМетаданных(ИмяТипа) Тогда
		СвойстваРегистра = СобратьСвойстваРегистра(ОбъектМД, ИмяТипа);
		Если СвойстваРегистра.Количество() > 0 Тогда
			Результат.Вставить("register_properties", СвойстваРегистра);
		КонецЕсли;
	КонецЕсли;

	Возврат ОтветJSON(200, Результат);
КонецФункции

// Безопасно получить свойство объекта метаданных по имени.
// Возвращает Неопределено, если свойства нет (разные виды объектов имеют
// разный набор — например, у ПВХ нет свойства "Владельцы").
Функция ЗначениеСвойстваОбъектаМД(ОбъектМД, ИмяСвойства)
	Значение = Неопределено;
	Попытка
		Значение = ОбъектМД[ИмяСвойства];
	Исключение
		Значение = Неопределено;
	КонецПопытки;
	Возврат Значение;
КонецФункции

// Источником UUID для ingest является ConfigDumpInfo.xml основной
// конфигурации. Поэтому runtime-метаданные, созданные расширениями, должны
// выглядеть для API как отсутствующие.
Функция ЭтоОбъектОсновнойКонфигурации(ОбъектМД)
	Если ОбъектМД = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Попытка
		Возврат ОбъектМД.РасширениеКонфигурации() = Неопределено;
	Исключение
		Возврат Истина;
	КонецПопытки;
КонецФункции

Функция ОбъектМетаданныхПоПолномуИмени(ПолноеИмя)
	Описание = ОписаниеОбъектаПоПолномуИмени(ПолноеИмя);
	Если Описание = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат НайтиОбъектМетаданных(Описание.object_type, Описание.name);
КонецФункции

Функция ЭтоПолноеИмяОбъектаОсновнойКонфигурации(ПолноеИмя)
	Возврат ОбъектМетаданныхПоПолномуИмени(ПолноеИмя) <> Неопределено;
КонецФункции

Функция СобратьСвойстваСправочника(ОбъектМД, ИмяТипа)
	Свойства = Новый Структура;

	Иерархический = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Иерархический");
	Если Иерархический <> Неопределено Тогда
		Свойства.Вставить("is_hierarchical", Иерархический);
		Если Иерархический Тогда
			ВидИерархии = ЗначениеСвойстваОбъектаМД(ОбъектМД, "ВидИерархии");
			Если ВидИерархии <> Неопределено Тогда
				ВидИерархииСтр = МаппингВидИерархии(Строка(ВидИерархии));
				Если ВидИерархииСтр <> Неопределено Тогда
					Свойства.Вставить("hierarchy_kind", ВидИерархииСтр);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	// Владельцы есть только у Справочников, не у ПВХ.
	Если ИмяТипа = "Catalogs" Тогда
		Владельцы = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Владельцы");
		Если Владельцы <> Неопределено Тогда
			ИменаВладельцев = Новый Массив;
			Для Каждого Владелец Из Владельцы Цикл
				Если НЕ ЭтоОбъектОсновнойКонфигурации(Владелец) Тогда
					Продолжить;
				КонецЕсли;
				ИменаВладельцев.Добавить(КаноническоеПолноеИмяОбъекта(Владелец));
			КонецЦикла;
			Свойства.Вставить("has_owner", ИменаВладельцев.Количество() > 0);
			Если ИменаВладельцев.Количество() > 0 Тогда
				Свойства.Вставить("owner_names", ИменаВладельцев);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	ДлинаКода = ЗначениеСвойстваОбъектаМД(ОбъектМД, "ДлинаКода");
	Если ДлинаКода <> Неопределено Тогда
		Свойства.Вставить("code_length", ДлинаКода);
	КонецЕсли;

	ДлинаНаименования = ЗначениеСвойстваОбъектаМД(ОбъектМД, "ДлинаНаименования");
	Если ДлинаНаименования <> Неопределено Тогда
		Свойства.Вставить("description_length", ДлинаНаименования);
	КонецЕсли;

	Возврат Свойства;
КонецФункции

Функция СобратьСвойстваДокумента(ОбъектМД)
	Свойства = Новый Структура;

	Проведение = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Проведение");
	Если Проведение <> Неопределено Тогда
		// ВозможностьПроведения.Разрешить / ВозможностьПроведения.Запретить
		Свойства.Вставить("is_postable", Строка(Проведение) = "Разрешить");
	КонецЕсли;

	Нумератор = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Нумератор");
	Если Нумератор <> Неопределено И ТипЗнч(Нумератор) <> Тип("Неопределено") Тогда
		Попытка
			Если ЭтоОбъектОсновнойКонфигурации(Нумератор) Тогда
				Свойства.Вставить("numerator_name", КаноническоеПолноеИмяОбъекта(Нумератор));
			КонецЕсли;
		Исключение
			// нумератор не задан — тихо пропускаем
		КонецПопытки;
	КонецЕсли;

	Периодичность = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Периодичность");
	Если Периодичность <> Неопределено Тогда
		ПериодичностьСтр = МаппингПериодичностиНомера(Строка(Периодичность));
		Если ПериодичностьСтр <> Неопределено Тогда
			Свойства.Вставить("numbering_periodicity", ПериодичностьСтр);
		КонецЕсли;
	КонецЕсли;

	ДлинаНомера = ЗначениеСвойстваОбъектаМД(ОбъектМД, "ДлинаНомера");
	Если ДлинаНомера <> Неопределено Тогда
		Свойства.Вставить("number_length", ДлинаНомера);
	КонецЕсли;

	Возврат Свойства;
КонецФункции

Функция СобратьСвойстваРегистра(ОбъектМД, ИмяТипа)
	Свойства = Новый Структура;

	Если ИмяТипа = "InformationRegisters" Тогда
		Свойства.Вставить("register_kind", "Information");

		Периодичность = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Периодичность");
		Если Периодичность <> Неопределено Тогда
			ПериодичностьСтр = МаппингПериодичностиРегистра(Строка(Периодичность));
			Если ПериодичностьСтр <> Неопределено Тогда
				Свойства.Вставить("periodicity", ПериодичностьСтр);
			КонецЕсли;
		КонецЕсли;

		РежимЗаписи = ЗначениеСвойстваОбъектаМД(ОбъектМД, "РежимЗаписи");
		Если РежимЗаписи <> Неопределено Тогда
			РежимЗаписиСтр = МаппингРежимаЗаписи(Строка(РежимЗаписи));
			Если РежимЗаписиСтр <> Неопределено Тогда
				Свойства.Вставить("write_mode", РежимЗаписиСтр);
			КонецЕсли;
		КонецЕсли;
	Иначе
		Если ИмяТипа = "AccumulationRegisters" Тогда
			Свойства.Вставить("register_kind", "Accumulation");
		ИначеЕсли ИмяТипа = "AccountingRegisters" Тогда
			Свойства.Вставить("register_kind", "Accounting");
		ИначеЕсли ИмяТипа = "CalculationRegisters" Тогда
			Свойства.Вставить("register_kind", "Calculation");
		КонецЕсли;
	КонецЕсли;

	Возврат Свойства;
КонецФункции

#КонецОбласти

#Область МаппингЯзыков

Функция МаппингВидИерархии(Значение)
	Если Значение = "ИерархияГруппИЭлементов" Тогда
		Возврат "HierarchyFoldersAndItems";
	ИначеЕсли Значение = "ИерархияЭлементов" Тогда
		Возврат "HierarchyOfItems";
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция МаппингПериодичностиНомера(Значение)
	Если Значение = "НеПериодический" Тогда
		Возврат "NonPeriodical";
	ИначеЕсли Значение = "Год" Тогда
		Возврат "Year";
	ИначеЕсли Значение = "Квартал" Тогда
		Возврат "Quarter";
	ИначеЕсли Значение = "Месяц" Тогда
		Возврат "Month";
	ИначеЕсли Значение = "День" Тогда
		Возврат "Day";
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция МаппингПериодичностиРегистра(Значение)
	Если Значение = "Непериодический" ИЛИ Значение = "НеПериодический" Тогда
		Возврат "NonPeriodical";
	ИначеЕсли Значение = "ВПределахСекунды" ИЛИ Значение = "Секунда" Тогда
		Возврат "Second";
	ИначеЕсли Значение = "Минута" Тогда
		Возврат "Minute";
	ИначеЕсли Значение = "Час" Тогда
		Возврат "Hour";
	ИначеЕсли Значение = "День" Тогда
		Возврат "Day";
	ИначеЕсли Значение = "Месяц" Тогда
		Возврат "Month";
	ИначеЕсли Значение = "Квартал" Тогда
		Возврат "Quarter";
	ИначеЕсли Значение = "Год" Тогда
		Возврат "Year";
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция МаппингРежимаЗаписи(Значение)
	Если Значение = "Независимый" Тогда
		Возврат "Independent";
	ИначеЕсли Значение = "ПодчинениеРегистратору" Тогда
		Возврат "RecorderSubordinate";
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

Функция СобратьРеквизиты(ОбъектМД, ИмяТипа)
	Если ИмяТипа = "Constants" Тогда
		Возврат СобратьРеквизитыКонстанты(ОбъектМД);
	КонецЕсли;

	Результат = Новый Массив;

	СтандартныеРеквизиты = ЗначениеСвойстваОбъектаМД(ОбъектМД, "СтандартныеРеквизиты");
	Если СтандартныеРеквизиты <> Неопределено Тогда
		Для Каждого СтандРекв Из СтандартныеРеквизиты Цикл
			Если НЕ ЭтоОбъектОсновнойКонфигурации(СтандРекв) Тогда
				Продолжить;
			КонецЕсли;
			Описание = ОписаниеРеквизита(СтандРекв);
			Если Описание = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			Описание.Вставить("role", "standard");
			Результат.Добавить(Описание);
		КонецЦикла;
	КонецЕсли;

	Реквизиты = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Реквизиты");
	Если Реквизиты <> Неопределено Тогда
		Для Каждого Реквизит Из Реквизиты Цикл
			Если НЕ ЭтоОбъектОсновнойКонфигурации(Реквизит) Тогда
				Продолжить;
			КонецЕсли;
			Описание = ОписаниеРеквизита(Реквизит);
			Если Описание = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			Описание.Вставить("role", "attribute");
			Результат.Добавить(Описание);
		КонецЦикла;
	КонецЕсли;

	ЭтоРегистр = ЭтоРегистрМетаданных(ИмяТипа);
	Если ЭтоРегистр Тогда
		Измерения = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Измерения");
		Если Измерения <> Неопределено Тогда
			Для Каждого Измерение Из Измерения Цикл
				Если НЕ ЭтоОбъектОсновнойКонфигурации(Измерение) Тогда
					Продолжить;
				КонецЕсли;
				Описание = ОписаниеРеквизита(Измерение);
				Если Описание = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				Описание.Вставить("role", "dimension");
				Результат.Добавить(Описание);
			КонецЦикла;
		КонецЕсли;
		Ресурсы = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Ресурсы");
		Если Ресурсы <> Неопределено Тогда
			Для Каждого Ресурс Из Ресурсы Цикл
				Если НЕ ЭтоОбъектОсновнойКонфигурации(Ресурс) Тогда
					Продолжить;
				КонецЕсли;
				Описание = ОписаниеРеквизита(Ресурс);
				Если Описание = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				Описание.Вставить("role", "resource");
				Результат.Добавить(Описание);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;

	Возврат Результат;
КонецФункции

Функция СобратьРеквизитыКонстанты(ОбъектМД)
	Результат = Новый Массив;

	ТипЗначения = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Тип");
	Если ТипЗначения = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Описание = Новый Структура;
	Описание.Вставить("name", "Value");
	Описание.Вставить("synonym", "Значение");
	Типы = МассивОписанийТипов(ТипЗначения);
	Если Типы.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	Описание.Вставить("types", Типы);
	Описание.Вставить("role", "attribute");
	Результат.Добавить(Описание);

	Возврат Результат;
КонецФункции

Функция ОписаниеРеквизита(Реквизит)
	Если НЕ ЭтоОбъектОсновнойКонфигурации(Реквизит) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Синоним = Реквизит.Синоним;
	Если ПустаяСтрока(Синоним) Тогда
		Синоним = Реквизит.Имя;
	КонецЕсли;

	Типы = МассивОписанийТипов(Реквизит.Тип);
	Если Типы.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Описание = Новый Структура;
	Описание.Вставить("name", Реквизит.Имя);
	Описание.Вставить("synonym", Синоним);
	Описание.Вставить("types", Типы);

	ДлинаСтроки = Реквизит.Тип.КвалификаторыСтроки.Длина;
	Если ДлинаСтроки > 0 Тогда
		Описание.Вставить("max_length", ДлинаСтроки);
	КонецЕсли;

	Возврат Описание;
КонецФункции

#КонецОбласти

#Область ТабличныеЧасти

Функция ТабличныеЧастиОбъекта(ИмяТипа, ИмяОбъекта)
	ОбъектМД = НайтиОбъектМетаданных(ИмяТипа, ИмяОбъекта);
	Если ОбъектМД = Неопределено Тогда
		Возврат ОтветОшибки(404, "Object not found: " + ИмяТипа + "." + ИмяОбъекта);
	КонецЕсли;

	Результат = Новый Массив;

	Попытка
		ТабЧасти = ОбъектМД.ТабличныеЧасти;
	Исключение
		Возврат ОтветJSON(200, Результат);
	КонецПопытки;

	Для Каждого ТабЧасть Из ТабЧасти Цикл
		Если НЕ ЭтоОбъектОсновнойКонфигурации(ТабЧасть) Тогда
			Продолжить;
		КонецЕсли;

		Синоним = ТабЧасть.Синоним;
		Если ПустаяСтрока(Синоним) Тогда
			Синоним = ТабЧасть.Имя;
		КонецЕсли;

		Реквизиты = Новый Массив;

		СтандартныеРеквизитыТЧ = ЗначениеСвойстваОбъектаМД(ТабЧасть, "СтандартныеРеквизиты");
		Если СтандартныеРеквизитыТЧ <> Неопределено Тогда
			Для Каждого СтандРекв Из СтандартныеРеквизитыТЧ Цикл
				Если НЕ ЭтоОбъектОсновнойКонфигурации(СтандРекв) Тогда
					Продолжить;
				КонецЕсли;
				Описание = ОписаниеРеквизита(СтандРекв);
				Если Описание = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				Описание.Вставить("role", "standard");
				Реквизиты.Добавить(Описание);
			КонецЦикла;
		КонецЕсли;

		РеквизитыТЧ = ЗначениеСвойстваОбъектаМД(ТабЧасть, "Реквизиты");
		Если РеквизитыТЧ <> Неопределено Тогда
			Для Каждого Реквизит Из РеквизитыТЧ Цикл
				Если НЕ ЭтоОбъектОсновнойКонфигурации(Реквизит) Тогда
					Продолжить;
				КонецЕсли;
				Описание = ОписаниеРеквизита(Реквизит);
				Если Описание = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				Описание.Вставить("role", "attribute");
				Реквизиты.Добавить(Описание);
			КонецЦикла;
		КонецЕсли;

		Описание = Новый Структура;
		Описание.Вставить("name", ТабЧасть.Имя);
		Описание.Вставить("synonym", Синоним);
		Описание.Вставить("attributes", Реквизиты);
		Результат.Добавить(Описание);
	КонецЦикла;

	Возврат ОтветJSON(200, Результат);
КонецФункции

#КонецОбласти

#Область РаботаСТипами

Функция МассивОписанийТипов(ОписаниеТипов)
	Результат = Новый Массив;

	Для Каждого ТекТип Из ОписаниеТипов.Типы() Цикл
		ИмяТипа = ИмяПримитивногоТипа(ТекТип);
		ЭтоСсылка = Ложь;

		Если ИмяТипа = Неопределено Тогда
			ОбъектМДТипа = Метаданные.НайтиПоТипу(ТекТип);
			Если ОбъектМДТипа <> Неопределено Тогда
				Если НЕ ЭтоОбъектОсновнойКонфигурации(ОбъектМДТипа) Тогда
					Продолжить;
				КонецЕсли;
				ИмяТипа = КаноническоеПолноеИмяОбъекта(ОбъектМДТипа);
				ЭтоСсылка = Истина;
			Иначе
				ИмяТипа = Строка(ТекТип);
			КонецЕсли;
		КонецЕсли;

		ОписаниеЭлемента = Новый Структура;
		ОписаниеЭлемента.Вставить("name", ИмяТипа);
		ОписаниеЭлемента.Вставить("is_reference", ЭтоСсылка);
		Результат.Добавить(ОписаниеЭлемента);
	КонецЦикла;

	Возврат Результат;
КонецФункции

#КонецОбласти

#Область РаботасСсылкамиОбъектов

Процедура СобратьСсылкиОбъекта(Результат, ОбъектМД, ИмяТипа, ДетальноКолонки, ФильтрОбъектов)
	Если НЕ ЭтоОбъектОсновнойКонфигурации(ОбъектМД) Тогда
		Возврат;
	КонецЕсли;

	ИмяИсточника = ОбъектМД.Имя;
	ПолноеИмяИсточника = КаноническоеПолноеИмяОбъекта(ОбъектМД);

	Если ИмяТипа = "Constants" Тогда
		ТипЗначения = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Тип");
		Если ТипЗначения <> Неопределено Тогда
			ДобавитьСсылкиОписанияТипов(Результат, ТипЗначения, "Value", ИмяТипа, ИмяИсточника, ПолноеИмяИсточника, Ложь, Неопределено, ДетальноКолонки, ФильтрОбъектов);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	// Стандартные реквизиты
	СтандартныеРеквизиты = ЗначениеСвойстваОбъектаМД(ОбъектМД, "СтандартныеРеквизиты");
	Если СтандартныеРеквизиты <> Неопределено Тогда
		Для Каждого СтандРекв Из СтандартныеРеквизиты Цикл
			ДобавитьСсылкиРеквизита(Результат, СтандРекв, ИмяТипа, ИмяИсточника, ПолноеИмяИсточника, Истина, Неопределено, ДетальноКолонки, ФильтрОбъектов);
		КонецЦикла;
	КонецЕсли;

	// Пользовательские реквизиты
	Реквизиты = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Реквизиты");
	Если Реквизиты <> Неопределено Тогда
		Для Каждого Реквизит Из Реквизиты Цикл
			ДобавитьСсылкиРеквизита(Результат, Реквизит, ИмяТипа, ИмяИсточника, ПолноеИмяИсточника, Ложь, Неопределено, ДетальноКолонки, ФильтрОбъектов);
		КонецЦикла;
	КонецЕсли;

	// Регистры: измерения и ресурсы
	ЭтоРегистр = ЭтоРегистрМетаданных(ИмяТипа);
	Если ЭтоРегистр Тогда
		Измерения = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Измерения");
		Если Измерения <> Неопределено Тогда
			Для Каждого Измерение Из Измерения Цикл
				ДобавитьСсылкиРеквизита(Результат, Измерение, ИмяТипа, ИмяИсточника, ПолноеИмяИсточника, Ложь, Неопределено, ДетальноКолонки, ФильтрОбъектов);
			КонецЦикла;
		КонецЕсли;
		Ресурсы = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Ресурсы");
		Если Ресурсы <> Неопределено Тогда
			Для Каждого Ресурс Из Ресурсы Цикл
				ДобавитьСсылкиРеквизита(Результат, Ресурс, ИмяТипа, ИмяИсточника, ПолноеИмяИсточника, Ложь, Неопределено, ДетальноКолонки, ФильтрОбъектов);
			КонецЦикла;
		КонецЕсли;
		Возврат;
	КонецЕсли;

	// Табличные части
	Попытка
		ТабЧасти = ОбъектМД.ТабличныеЧасти;
	Исключение
		Возврат;
	КонецПопытки;

	Для Каждого ТабЧасть Из ТабЧасти Цикл
		Если НЕ ЭтоОбъектОсновнойКонфигурации(ТабЧасть) Тогда
			Продолжить;
		КонецЕсли;

		СтандартныеРеквизитыТЧ = ЗначениеСвойстваОбъектаМД(ТабЧасть, "СтандартныеРеквизиты");
		Если СтандартныеРеквизитыТЧ <> Неопределено Тогда
			Для Каждого СтандРекв Из СтандартныеРеквизитыТЧ Цикл
				ДобавитьСсылкиРеквизита(Результат, СтандРекв, ИмяТипа, ИмяИсточника, ПолноеИмяИсточника, Истина, ТабЧасть.Имя, ДетальноКолонки, ФильтрОбъектов);
			КонецЦикла;
		КонецЕсли;
		РеквизитыТЧ = ЗначениеСвойстваОбъектаМД(ТабЧасть, "Реквизиты");
		Если РеквизитыТЧ <> Неопределено Тогда
			Для Каждого Реквизит Из РеквизитыТЧ Цикл
				ДобавитьСсылкиРеквизита(Результат, Реквизит, ИмяТипа, ИмяИсточника, ПолноеИмяИсточника, Ложь, ТабЧасть.Имя, ДетальноКолонки, ФильтрОбъектов);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

#КонецОбласти

#Область РаботаСРеквизитами

Процедура ДобавитьСсылкиРеквизита(Результат, Реквизит, ИмяТипаИсточника, ИмяИсточника, ПолноеИмяИсточника, ЭтоСтандартныйРеквизит, ИмяТабличнойЧасти, ДетальноКолонки, ФильтрОбъектов)
	Если НЕ ЭтоОбъектОсновнойКонфигурации(Реквизит) Тогда
		Возврат;
	КонецЕсли;

	ОписаниеТипов = Реквизит.Тип;
	ДобавитьСсылкиОписанияТипов(Результат, ОписаниеТипов, Реквизит.Имя, ИмяТипаИсточника, ИмяИсточника, ПолноеИмяИсточника, ЭтоСтандартныйРеквизит, ИмяТабличнойЧасти, ДетальноКолонки, ФильтрОбъектов);
КонецПроцедуры

Процедура ДобавитьСсылкиОписанияТипов(Результат, ОписаниеТипов, ИмяРеквизита, ИмяТипаИсточника, ИмяИсточника, ПолноеИмяИсточника, ЭтоСтандартныйРеквизит, ИмяТабличнойЧасти, ДетальноКолонки, ФильтрОбъектов)
	Для Каждого ТекТип Из ОписаниеТипов.Типы() Цикл
		Если ИмяПримитивногоТипа(ТекТип) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ОбъектМДТипа = Метаданные.НайтиПоТипу(ТекТип);
		Если ОбъектМДТипа = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Если НЕ ЭтоОбъектОсновнойКонфигурации(ОбъектМДТипа) Тогда
			Продолжить;
		КонецЕсли;

		ЦелевоеПолноеИмя = КаноническоеПолноеИмяОбъекта(ОбъектМДТипа);
		// Стандартный реквизит "Ссылка" технически имеет тип самого объекта.
		// Это идентификатор текущей записи, а не доменная ссылка объекта на себя.
		Если ЭтоСтандартныйРеквизит
			И ИмяРеквизита = "Ссылка"
			И ЦелевоеПолноеИмя = ПолноеИмяИсточника Тогда
			Продолжить;
		КонецЕсли;

		Если ФильтрОбъектов.Количество() > 0
			И ФильтрОбъектов.Получить(ЦелевоеПолноеИмя) = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Части = СтрРазделить(ЦелевоеПолноеИмя, ".");
		Если Части.Количество() < 2 Тогда
			Продолжить;
		КонецЕсли;

		Ссылка = Новый Структура;
		Ссылка.Вставить("source_object_type", ИмяТипаИсточника);
		Ссылка.Вставить("source_name", ИмяИсточника);
		Ссылка.Вставить("target_object_type", ИмяТипаОбъектаПоПолномуИмени(Части[0]));
		Ссылка.Вставить("target_name", Части[1]);
		Если ИмяТабличнойЧасти <> Неопределено Тогда
			Ссылка.Вставить("source_tabular_part", ИмяТабличнойЧасти);
		КонецЕсли;

		Если ДетальноКолонки Тогда
			Ссылка.Вставить("source_attribute", ИмяРеквизита);
			Ссылка.Вставить("target_attribute", "Ссылка");
		КонецЕсли;

		Результат.Добавить(Ссылка);
	КонецЦикла;
КонецПроцедуры

Функция ИмяТипаОбъектаПоПолномуИмени(ИмяТипаВнутр)
	Если ИмяТипаВнутр = "Catalog" ИЛИ ИмяТипаВнутр = "Справочник" Тогда
		Возврат "Catalogs";
	ИначеЕсли ИмяТипаВнутр = "Constant" ИЛИ ИмяТипаВнутр = "Константа" Тогда
		Возврат "Constants";
	ИначеЕсли ИмяТипаВнутр = "Document" ИЛИ ИмяТипаВнутр = "Документ" Тогда
		Возврат "Documents";
	ИначеЕсли ИмяТипаВнутр = "ChartOfCharacteristicTypes" ИЛИ ИмяТипаВнутр = "ПланВидовХарактеристик" Тогда
		Возврат "ChartsOfCharacteristicTypes";
	ИначеЕсли ИмяТипаВнутр = "ChartOfAccounts" ИЛИ ИмяТипаВнутр = "ПланСчетов" Тогда
		Возврат "ChartsOfAccounts";
	ИначеЕсли ИмяТипаВнутр = "ChartOfCalculationTypes" ИЛИ ИмяТипаВнутр = "ПланВидовРасчета" Тогда
		Возврат "ChartsOfCalculationTypes";
	ИначеЕсли ИмяТипаВнутр = "InformationRegister" ИЛИ ИмяТипаВнутр = "РегистрСведений" Тогда
		Возврат "InformationRegisters";
	ИначеЕсли ИмяТипаВнутр = "AccumulationRegister" ИЛИ ИмяТипаВнутр = "РегистрНакопления" Тогда
		Возврат "AccumulationRegisters";
	ИначеЕсли ИмяТипаВнутр = "AccountingRegister" ИЛИ ИмяТипаВнутр = "РегистрБухгалтерии" Тогда
		Возврат "AccountingRegisters";
	ИначеЕсли ИмяТипаВнутр = "CalculationRegister" ИЛИ ИмяТипаВнутр = "РегистрРасчета" Тогда
		Возврат "CalculationRegisters";
	ИначеЕсли ИмяТипаВнутр = "Enum" ИЛИ ИмяТипаВнутр = "Перечисление" Тогда
		Возврат "Enums";
	Иначе
		Возврат ИмяТипаВнутр;
	КонецЕсли;
КонецФункции

Функция КаноническийПрефиксПоПрефиксуПолногоИмени(Префикс)
	Если Префикс = "Catalog" ИЛИ Префикс = "Справочник" Тогда
		Возврат "Catalog";
	ИначеЕсли Префикс = "Constant" ИЛИ Префикс = "Константа" Тогда
		Возврат "Constant";
	ИначеЕсли Префикс = "Document" ИЛИ Префикс = "Документ" Тогда
		Возврат "Document";
	ИначеЕсли Префикс = "ChartOfCharacteristicTypes" ИЛИ Префикс = "ПланВидовХарактеристик" Тогда
		Возврат "ChartOfCharacteristicTypes";
	ИначеЕсли Префикс = "ChartOfAccounts" ИЛИ Префикс = "ПланСчетов" Тогда
		Возврат "ChartOfAccounts";
	ИначеЕсли Префикс = "ChartOfCalculationTypes" ИЛИ Префикс = "ПланВидовРасчета" Тогда
		Возврат "ChartOfCalculationTypes";
	ИначеЕсли Префикс = "InformationRegister" ИЛИ Префикс = "РегистрСведений" Тогда
		Возврат "InformationRegister";
	ИначеЕсли Префикс = "AccumulationRegister" ИЛИ Префикс = "РегистрНакопления" Тогда
		Возврат "AccumulationRegister";
	ИначеЕсли Префикс = "AccountingRegister" ИЛИ Префикс = "РегистрБухгалтерии" Тогда
		Возврат "AccountingRegister";
	ИначеЕсли Префикс = "CalculationRegister" ИЛИ Префикс = "РегистрРасчета" Тогда
		Возврат "CalculationRegister";
	ИначеЕсли Префикс = "Enum" ИЛИ Префикс = "Перечисление" Тогда
		Возврат "Enum";
	ИначеЕсли Префикс = "HTTPService" ИЛИ Префикс = "HTTPСервис" Тогда
		Возврат "HTTPService";
	ИначеЕсли Префикс = "WebService" ИЛИ Префикс = "WebСервис" Тогда
		Возврат "WebService";
	Иначе
		Возврат Префикс;
	КонецЕсли;
КонецФункции

Функция КаноническоеПолноеИмяИзПолногоИмени(ПолноеИмя)
	Если ПолноеИмя = Неопределено Тогда
		Возврат ПолноеИмя;
	КонецЕсли;
	Если ПустаяСтрока(ПолноеИмя) Тогда
		Возврат ПолноеИмя;
	КонецЕсли;

	Части = СтрРазделить(ПолноеИмя, ".");
	Если Части.Количество() < 2 Тогда
		Возврат ПолноеИмя;
	КонецЕсли;

	Части[0] = КаноническийПрефиксПоПрефиксуПолногоИмени(Части[0]);
	Возврат СтрСоединить(Части, ".");
КонецФункции

Функция КаноническоеПолноеИмяОбъекта(ОбъектМД)
	Попытка
		Возврат КаноническоеПолноеИмяИзПолногоИмени(ОбъектМД.ПолноеИмя());
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

Функция ДедублироватьСсылки(Ссылки)
	Результат = Новый Массив;
	Ключи = Новый Соответствие;

	Для Каждого Ссылка Из Ссылки Цикл
		ИмяТЧИсточника = "";
		Ссылка.Свойство("source_tabular_part", ИмяТЧИсточника);
		Ключ = Ссылка.source_object_type + "|" + Ссылка.source_name + "|"
			+ ИмяТЧИсточника + "|"
			+ Ссылка.target_object_type + "|" + Ссылка.target_name;
		Если Ключи.Получить(Ключ) = Неопределено Тогда
			Ключи.Вставить(Ключ, Истина);
			Результат.Добавить(Ссылка);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область РаботаСDatasetLineage

Функция ФильтрСпискаПоПараметру(Запрос, ИмяПараметра)
	Фильтр = Новый Соответствие;
	СтрокаПараметра = Запрос.ПараметрыЗапроса.Получить(ИмяПараметра);
	Если СтрокаПараметра <> Неопределено И НЕ ПустаяСтрока(СтрокаПараметра) Тогда
		Для Каждого Элемент Из СтрРазделить(СтрокаПараметра, ",") Цикл
			ЗначениеФильтра = СокрЛП(Элемент);
			Если НЕ ПустаяСтрока(ЗначениеФильтра) Тогда
				Фильтр.Вставить(ЗначениеФильтра, Истина);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат Фильтр;
КонецФункции

Функция ФильтрСпискаОбъектовПоПараметру(Запрос, ИмяПараметра)
	Фильтр = Новый Соответствие;
	СтрокаПараметра = Запрос.ПараметрыЗапроса.Получить(ИмяПараметра);
	Если СтрокаПараметра <> Неопределено И НЕ ПустаяСтрока(СтрокаПараметра) Тогда
		Для Каждого Элемент Из СтрРазделить(СтрокаПараметра, ",") Цикл
			ЗначениеФильтра = КаноническоеПолноеИмяИзПолногоИмени(СокрЛП(Элемент));
			Если НЕ ПустаяСтрока(ЗначениеФильтра) Тогда
				Фильтр.Вставить(ЗначениеФильтра, Истина);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат Фильтр;
КонецФункции

#КонецОбласти

#Область ДанныеСервисовИнтеграций

Функция ТипИнтеграционногоСервисаРазрешен(ФильтрТипов, ИмяТипа)
	Возврат ФильтрТипов.Количество() = 0
		ИЛИ ФильтрТипов.Получить(ИмяТипа) <> Неопределено;
КонецФункции

Процедура СобратьHTTPСервисы(Результат, ФильтрСервисов, ФильтрЭндпоинтов, ВнутренниеВходы)
	Попытка
		Сервисы = Метаданные.HTTPСервисы;
	Исключение
		Возврат;
	КонецПопытки;

	Для Каждого СервисМД Из Сервисы Цикл
		Если НЕ ЭтоОбъектОсновнойКонфигурации(СервисМД) Тогда
			Продолжить;
		КонецЕсли;

		ПолноеИмяСервиса = ПолноеИмяHTTPСервиса(СервисМД);
		Если НЕ ИнтеграционныйСервисРазрешен(ФильтрСервисов, ПолноеИмяСервиса) Тогда
			Продолжить;
		КонецЕсли;

		Эндпоинты = СобратьМетодыHTTPСервиса(
			СервисМД,
			ФильтрЭндпоинтов,
			ВнутренниеВходы
		);
		Если Эндпоинты.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;

		Описание = БазовоеОписаниеИнтеграционногоСервиса(
			"HTTPServices",
			СервисМД,
			ПолноеИмяСервиса
		);
		ДобавитьЕслиЗаполнено(Описание, "root_url", ЗначениеСвойстваОбъектаМД(СервисМД, "КорневойURL"));
		ДобавитьЕслиЗаполнено(Описание, "root_url", ЗначениеСвойстваОбъектаМД(СервисМД, "RootURL"));
		ДобавитьЕслиЗаполнено(Описание, "reuse_sessions", ЗначениеСвойстваОбъектаМД(СервисМД, "ПовторноеИспользованиеСеансов"));
		ДобавитьЕслиЗаполнено(Описание, "reuse_sessions", ЗначениеСвойстваОбъектаМД(СервисМД, "ReuseSessions"));
		ДобавитьЕслиЗаполнено(Описание, "session_max_age", ЗначениеСвойстваОбъектаМД(СервисМД, "МаксимальныйВозрастСеанса"));
		ДобавитьЕслиЗаполнено(Описание, "session_max_age", ЗначениеСвойстваОбъектаМД(СервисМД, "SessionMaxAge"));
		Описание.Вставить("endpoints", Эндпоинты);
		Результат.Добавить(Описание);
	КонецЦикла;
КонецПроцедуры

Процедура СобратьWebСервисы(Результат, ФильтрСервисов, ФильтрЭндпоинтов, ВнутренниеВходы)
	Попытка
		Сервисы = Метаданные.WebСервисы;
	Исключение
		Возврат;
	КонецПопытки;

	Для Каждого СервисМД Из Сервисы Цикл
		Если НЕ ЭтоОбъектОсновнойКонфигурации(СервисМД) Тогда
			Продолжить;
		КонецЕсли;

		ПолноеИмяСервиса = ПолноеИмяWebСервиса(СервисМД);
		Если НЕ ИнтеграционныйСервисРазрешен(ФильтрСервисов, ПолноеИмяСервиса) Тогда
			Продолжить;
		КонецЕсли;

		Эндпоинты = СобратьОперацииWebСервиса(
			СервисМД,
			ФильтрЭндпоинтов,
			ВнутренниеВходы
		);
		Если Эндпоинты.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;

		Описание = БазовоеОписаниеИнтеграционногоСервиса(
			"WebServices",
			СервисМД,
			ПолноеИмяСервиса
		);
		ДобавитьЕслиЗаполнено(Описание, "namespace", ЗначениеСвойстваОбъектаМД(СервисМД, "ПространствоИмен"));
		ДобавитьЕслиЗаполнено(Описание, "namespace", ЗначениеСвойстваОбъектаМД(СервисМД, "Namespace"));
		ДобавитьЕслиЗаполнено(Описание, "descriptor_file_name", ЗначениеСвойстваОбъектаМД(СервисМД, "ИмяФайлаПубликации"));
		ДобавитьЕслиЗаполнено(Описание, "descriptor_file_name", ЗначениеСвойстваОбъектаМД(СервисМД, "DescriptorFileName"));
		Описание.Вставить("endpoints", Эндпоинты);
		Результат.Добавить(Описание);
	КонецЦикла;
КонецПроцедуры

Функция СобратьМетодыHTTPСервиса(СервисМД, ФильтрЭндпоинтов, ВнутренниеВходы)
	Результат = Новый Массив;
	Шаблоны = ЗначениеПервогоСвойстваОбъектаМД(СервисМД, ИменаСвойств("ШаблоныURL", "URLTemplates"));
	Если Шаблоны = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого ШаблонМД Из Шаблоны Цикл
		Если НЕ ЭтоОбъектОсновнойКонфигурации(ШаблонМД) Тогда
			Продолжить;
		КонецЕсли;

		Методы = ЗначениеПервогоСвойстваОбъектаМД(ШаблонМД, ИменаСвойств("Методы", "Methods"));
		Если Методы = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого МетодМД Из Методы Цикл
			Если НЕ ЭтоОбъектОсновнойКонфигурации(МетодМД) Тогда
				Продолжить;
			КонецЕсли;

			ПолноеИмяМетода = ПолноеИмяМетодаHTTPСервиса(СервисМД, ШаблонМД, МетодМД);
			Если НЕ ЭндпоинтИнтеграционногоСервисаРазрешен(ФильтрЭндпоинтов, ПолноеИмяМетода) Тогда
				Продолжить;
			КонецЕсли;

			Описание = Новый Структура;
			Описание.Вставить("endpoint_type", "http_method");
			Описание.Вставить("name", МетодМД.Имя);
			Описание.Вставить("full_name", ПолноеИмяМетода);
			Описание.Вставить("url_template_name", ШаблонМД.Имя);
			Описание.Вставить("url_template_full_name", ПолноеИмяШаблонаURLHTTPСервиса(СервисМД, ШаблонМД));
			ДобавитьЕслиЗаполнено(Описание, "url_template", ЗначениеСвойстваОбъектаМД(ШаблонМД, "Шаблон"));
			ДобавитьЕслиЗаполнено(Описание, "url_template", ЗначениеСвойстваОбъектаМД(ШаблонМД, "Template"));
			Описание.Вставить("method_name", МетодМД.Имя);
			ДобавитьЕслиЗаполнено(Описание, "http_method", ЗначениеПервогоСвойстваОбъектаМД(МетодМД, ИменаСвойств("HTTPМетод", "HTTPMethod")));
			ДобавитьЕслиЗаполнено(Описание, "handler", ЗначениеСвойстваОбъектаМД(МетодМД, "Обработчик"));
			ДобавитьЕслиЗаполнено(Описание, "handler", ЗначениеСвойстваОбъектаМД(МетодМД, "Handler"));
			ДобавитьСинонимИКомментарий(Описание, МетодМД);
			Описание.Вставить("input_objects", ВходыЭндпоинта(ВнутренниеВходы, ПолноеИмяМетода));
			Результат.Добавить(Описание);
		КонецЦикла;
	КонецЦикла;

	Возврат Результат;
КонецФункции

Функция СобратьОперацииWebСервиса(СервисМД, ФильтрЭндпоинтов, ВнутренниеВходы)
	Результат = Новый Массив;
	Операции = ЗначениеПервогоСвойстваОбъектаМД(СервисМД, ИменаСвойств("Операции", "Operations"));
	Если Операции = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого ОперацияМД Из Операции Цикл
		Если НЕ ЭтоОбъектОсновнойКонфигурации(ОперацияМД) Тогда
			Продолжить;
		КонецЕсли;

		ПолноеИмяОперации = ПолноеИмяОперацииWebСервиса(СервисМД, ОперацияМД);
		Если НЕ ЭндпоинтИнтеграционногоСервисаРазрешен(ФильтрЭндпоинтов, ПолноеИмяОперации) Тогда
			Продолжить;
		КонецЕсли;

		Описание = Новый Структура;
		Описание.Вставить("endpoint_type", "web_operation");
		Описание.Вставить("name", ОперацияМД.Имя);
		Описание.Вставить("full_name", ПолноеИмяОперации);
		Описание.Вставить("operation_name", ОперацияМД.Имя);
		ДобавитьЕслиЗаполнено(Описание, "procedure_name", ЗначениеСвойстваОбъектаМД(ОперацияМД, "ИмяПроцедуры"));
		ДобавитьЕслиЗаполнено(Описание, "procedure_name", ЗначениеСвойстваОбъектаМД(ОперацияМД, "ProcedureName"));
		ДобавитьЕслиЗаполнено(Описание, "transactioned", ЗначениеСвойстваОбъектаМД(ОперацияМД, "Транзакционная"));
		ДобавитьЕслиЗаполнено(Описание, "transactioned", ЗначениеСвойстваОбъектаМД(ОперацияМД, "Transactioned"));
		ДобавитьЕслиЗаполнено(Описание, "nillable", ЗначениеСвойстваОбъектаМД(ОперацияМД, "Nillable"));
		ДобавитьЕслиЗаполнено(Описание, "data_lock_control_mode", ЗначениеСвойстваОбъектаМД(ОперацияМД, "РежимУправленияБлокировкойДанных"));
		ДобавитьЕслиЗаполнено(Описание, "data_lock_control_mode", ЗначениеСвойстваОбъектаМД(ОперацияМД, "DataLockControlMode"));
		ДобавитьЕслиЗаполнено(Описание, "return_xdto_type", ЗначениеСвойстваОбъектаМД(ОперацияМД, "ТипВозвращаемогоЗначения"));
		ДобавитьЕслиЗаполнено(Описание, "return_xdto_type", ЗначениеСвойстваОбъектаМД(ОперацияМД, "ReturnValueType"));
		ДобавитьСинонимИКомментарий(Описание, ОперацияМД);
		Описание.Вставить("parameters", СобратьПараметрыОперацииWebСервиса(ОперацияМД));
		Описание.Вставить("input_objects", ВходыЭндпоинта(ВнутренниеВходы, ПолноеИмяОперации));
		Результат.Добавить(Описание);
	КонецЦикла;

	Возврат Результат;
КонецФункции

Функция СобратьПараметрыОперацииWebСервиса(ОперацияМД)
	Результат = Новый Массив;
	Параметры = ЗначениеПервогоСвойстваОбъектаМД(ОперацияМД, ИменаСвойств("Параметры", "Parameters"));
	Если Параметры = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого ПараметрМД Из Параметры Цикл
		Если НЕ ЭтоОбъектОсновнойКонфигурации(ПараметрМД) Тогда
			Продолжить;
		КонецЕсли;

		Описание = Новый Структура;
		Описание.Вставить("name", ПараметрМД.Имя);
		ДобавитьЕслиЗаполнено(Описание, "direction", ЗначениеСвойстваОбъектаМД(ПараметрМД, "Направление"));
		ДобавитьЕслиЗаполнено(Описание, "direction", ЗначениеСвойстваОбъектаМД(ПараметрМД, "Direction"));
		ДобавитьЕслиЗаполнено(Описание, "xdto_type", ЗначениеСвойстваОбъектаМД(ПараметрМД, "ТипXDTO"));
		ДобавитьЕслиЗаполнено(Описание, "xdto_type", ЗначениеСвойстваОбъектаМД(ПараметрМД, "XDTOType"));
		ДобавитьЕслиЗаполнено(Описание, "nillable", ЗначениеСвойстваОбъектаМД(ПараметрМД, "Nillable"));
		Результат.Добавить(Описание);
	КонецЦикла;

	Возврат Результат;
КонецФункции

Функция БазовоеОписаниеИнтеграционногоСервиса(ТипСервиса, СервисМД, ПолноеИмяСервиса)
	Описание = Новый Структура;
	Описание.Вставить("service_type", ТипСервиса);
	Описание.Вставить("name", СервисМД.Имя);
	Описание.Вставить("full_name", ПолноеИмяСервиса);
	ДобавитьСинонимИКомментарий(Описание, СервисМД);
	Возврат Описание;
КонецФункции

Функция ИнтеграционныйСервисРазрешен(ФильтрСервисов, ПолноеИмяСервиса)
	Возврат ФильтрСервисов.Количество() = 0
		ИЛИ ФильтрСервисов.Получить(ПолноеИмяСервиса) <> Неопределено;
КонецФункции

Функция ЭндпоинтИнтеграционногоСервисаРазрешен(ФильтрЭндпоинтов, ПолноеИмяЭндпоинта)
	Возврат ФильтрЭндпоинтов.Количество() = 0
		ИЛИ ФильтрЭндпоинтов.Получить(ПолноеИмяЭндпоинта) <> Неопределено;
КонецФункции

Функция ПолноеИмяHTTPСервиса(СервисМД)
	Возврат "HTTPService." + СервисМД.Имя;
КонецФункции

Функция ПолноеИмяWebСервиса(СервисМД)
	Возврат "WebService." + СервисМД.Имя;
КонецФункции

Функция ПолноеИмяШаблонаURLHTTPСервиса(СервисМД, ШаблонМД)
	Возврат ПолноеИмяHTTPСервиса(СервисМД) + ".URLTemplate." + ШаблонМД.Имя;
КонецФункции

Функция ПолноеИмяМетодаHTTPСервиса(СервисМД, ШаблонМД, МетодМД)
	Возврат ПолноеИмяШаблонаURLHTTPСервиса(СервисМД, ШаблонМД) + ".Method." + МетодМД.Имя;
КонецФункции

Функция ПолноеИмяОперацииWebСервиса(СервисМД, ОперацияМД)
	Возврат ПолноеИмяWebСервиса(СервисМД) + ".Operation." + ОперацияМД.Имя;
КонецФункции

Процедура ДобавитьСинонимИКомментарий(Описание, ОбъектМД)
	Синоним = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Синоним");
	Если Синоним <> Неопределено И НЕ ПустаяСтрока(Синоним) Тогда
		Описание.Вставить("synonym", Синоним);
	КонецЕсли;

	Комментарий = ЗначениеСвойстваОбъектаМД(ОбъектМД, "Комментарий");
	Если Комментарий <> Неопределено И НЕ ПустаяСтрока(Комментарий) Тогда
		Описание.Вставить("comment", Комментарий);
	КонецЕсли;
КонецПроцедуры

Процедура ДобавитьЕслиЗаполнено(Описание, ИмяПоля, Значение)
	Если Значение = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Строка") И ПустаяСтрока(Значение) Тогда
		Возврат;
	КонецЕсли;
	Если Описание.Свойство(ИмяПоля) Тогда
		Возврат;
	КонецЕсли;
	Описание.Вставить(ИмяПоля, JSONСовместимоеЗначение(Значение));
КонецПроцедуры

Функция JSONСовместимоеЗначение(Значение)
	ТипЗначения = ТипЗнч(Значение);
	Если ТипЗначения = Тип("Строка")
		ИЛИ ТипЗначения = Тип("Число")
		ИЛИ ТипЗначения = Тип("Булево")
		ИЛИ ТипЗначения = Тип("Дата") Тогда
		Возврат Значение;
	КонецЕсли;
	Возврат Строка(Значение);
КонецФункции

Функция ВходыЭндпоинта(ВнутренниеВходы, ПолноеИмяЭндпоинта)
	Результат = ВнутренниеВходы.Получить(ПолноеИмяЭндпоинта);
	Если Результат = Неопределено Тогда
		Результат = Новый Массив;
	КонецЕсли;
	Возврат Результат;
КонецФункции

Процедура ПроверитьВнутренниеВходыИнтеграционныхСервисов(ВнутренниеВходы, Сервисы)
	Если ВнутренниеВходы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	СуществующиеЭндпоинты = Новый Соответствие;
	Для Каждого Сервис Из Сервисы Цикл
		Эндпоинты = Новый Массив;
		Если Сервис.Свойство("endpoints", Эндпоинты) Тогда
			Для Каждого Эндпоинт Из Эндпоинты Цикл
				ПолноеИмяЭндпоинта = "";
				Если Эндпоинт.Свойство("full_name", ПолноеИмяЭндпоинта) Тогда
					СуществующиеЭндпоинты.Вставить(ПолноеИмяЭндпоинта, Истина);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;

	Для Каждого ЭлементВходов Из ВнутренниеВходы Цикл
		Если СуществующиеЭндпоинты.Получить(ЭлементВходов.Ключ) = Неопределено Тогда
			ВызватьИсключение "Manual integration service input references unknown or filtered endpoint: "
				+ ЭлементВходов.Ключ;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

Функция ВнутренниеВходыИнтеграционныхСервисов(ФильтрТипов, ФильтрСервисов, ФильтрЭндпоинтов)
	Результат = Новый Соответствие;
	РучныеСвязи = Новый Массив;
	Контекст = Новый Структура;
	Контекст.Вставить("filter_types", ФильтрТипов);
	Контекст.Вставить("filter_services", ФильтрСервисов);
	Контекст.Вставить("filter_endpoints", ФильтрЭндпоинтов);

	Попытка
		mds_ManualLineage.ДополнитьИнтеграционныеСервисы(РучныеСвязи, Контекст);
	Исключение
		ВызватьИсключение "Ошибка получения мануальных внутренних связей интеграционных сервисов: "
			+ ОписаниеОшибки();
	КонецПопытки;

	Для Каждого РучноеПравило Из РучныеСвязи Цикл
			ДобавитьВнутреннийВходИнтеграционногоСервиса(
				Результат,
				ФильтрТипов,
				ФильтрСервисов,
				ФильтрЭндпоинтов,
				РучноеПравило
		);
	КонецЦикла;

	Возврат Результат;
КонецФункции

Процедура ДобавитьВнутреннийВходИнтеграционногоСервиса(
	Результат,
	ФильтрТипов,
	ФильтрСервисов,
	ФильтрЭндпоинтов,
	РучноеПравило
)
	ВидСвязи = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("ВидСвязи", "kind"), "integration_service_input");
	Если ВидСвязи <> "integration_service_input" Тогда
		ВызватьИсключение "Неподдерживаемый вид связи интеграционного сервиса: " + ВидСвязи;
	КонецЕсли;

	ПолноеИмяЭндпоинта = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("Эндпоинт", "endpoint"), Неопределено);
	Если ПолноеИмяЭндпоинта = Неопределено Тогда
		ВызватьИсключение "Связь интеграционного сервиса не содержит endpoint.";
	КонецЕсли;
	ПолноеИмяЭндпоинта = КаноническоеПолноеИмяИзПолногоИмени(ПолноеИмяЭндпоинта);
	ПолноеИмяСервиса = ПолноеИмяСервисаПоЭндпоинту(ПолноеИмяЭндпоинта);
	ТипСервиса = ТипИнтеграционногоСервисаПоПолномуИмени(ПолноеИмяСервиса);
	Если ТипСервиса = Неопределено Тогда
		ВызватьИсключение "Неподдерживаемый эндпойнт интеграционного сервиса: " + ПолноеИмяЭндпоинта;
	КонецЕсли;
	Если НЕ ТипИнтеграционногоСервисаРазрешен(ФильтрТипов, ТипСервиса) Тогда
		Возврат;
	КонецЕсли;
	Если НЕ ИнтеграционныйСервисРазрешен(ФильтрСервисов, ПолноеИмяСервиса) Тогда
		Возврат;
	КонецЕсли;
	Если НЕ ЭндпоинтИнтеграционногоСервисаСуществует(ТипСервиса, ПолноеИмяЭндпоинта, Ложь) Тогда
		ВызватьИсключение "Manual integration service input references unknown endpoint: "
			+ ПолноеИмяЭндпоинта;
	КонецЕсли;
	Если НЕ ЭндпоинтИнтеграционногоСервисаСуществует(ТипСервиса, ПолноеИмяЭндпоинта) Тогда
		Возврат;
	КонецЕсли;
	Если НЕ ЭндпоинтИнтеграционногоСервисаРазрешен(ФильтрЭндпоинтов, ПолноеИмяЭндпоинта) Тогда
		Возврат;
	КонецЕсли;

	ОбъектИсточник = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("ОбъектИсточник", "input"), Неопределено);
	Если ОбъектИсточник = Неопределено Тогда
		ВызватьИсключение "Связь интеграционного сервиса не содержит входящего объекта.";
	КонецЕсли;
	Если ЗначениеМетаданныхРасширенияКонфигурации(ОбъектИсточник) Тогда
		Возврат;
	КонецЕсли;

	ПолноеИмяОбъекта = ПолноеИмяЗначенияМетаданных(ОбъектИсточник);
	Если ПолноеИмяОбъекта = Неопределено Тогда
		ВызватьИсключение "Не удалось определить связи входящего объекта интеграционного сервиса.";
	КонецЕсли;
	ПроверитьОбъектManualLineage(ПолноеИмяОбъекта, "integration service input");
	ОписаниеОбъекта = ОписаниеОбъектаПоПолномуИмени(ПолноеИмяОбъекта);

	Источник = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("ИсточникСвязи", "source"), "manual");
	Уверенность = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("Уверенность", "confidence"), "high");
	ПроверитьИсточникManualLineage(Источник);
	ПроверитьУверенностьManualLineage(Уверенность);

	Вход = Новый Структура;
	Вход.Вставить("object_type", ОписаниеОбъекта.object_type);
	Вход.Вставить("name", ОписаниеОбъекта.name);
	Вход.Вставить("full_name", ОписаниеОбъекта.full_name);
	Вход.Вставить("source", Источник);
	Вход.Вставить("confidence", Уверенность);

	Описание = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("Описание", "description"), Неопределено);
	Если Описание <> Неопределено И НЕ ПустаяСтрока(Описание) Тогда
		Вход.Вставить("description", Описание);
	КонецЕсли;

	Детали = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("Детали", "details"), Неопределено);
	Если Детали <> Неопределено И Детали.Количество() > 0 Тогда
		Вход.Вставить("details", Детали);
	КонецЕсли;

	ВходыЭндпоинта = Результат.Получить(ПолноеИмяЭндпоинта);
	Если ВходыЭндпоинта = Неопределено Тогда
		ВходыЭндпоинта = Новый Массив;
		Результат.Вставить(ПолноеИмяЭндпоинта, ВходыЭндпоинта);
	КонецЕсли;
	ВходыЭндпоинта.Добавить(Вход);
КонецПроцедуры

Функция ПолноеИмяСервисаПоЭндпоинту(ПолноеИмяЭндпоинта)
	Части = СтрРазделить(ПолноеИмяЭндпоинта, ".");
	Если Части.Количество() < 2 Тогда
		Возврат ПолноеИмяЭндпоинта;
	КонецЕсли;
	Возврат Части[0] + "." + Части[1];
КонецФункции

Функция ЭндпоинтИнтеграционногоСервисаСуществует(ТипСервиса, ПолноеИмяЭндпоинта, ТолькоОсновнаяКонфигурация = Истина)
	Если ТипСервиса = "HTTPServices" Тогда
		Возврат МетодHTTPСервисаСуществует(ПолноеИмяЭндпоинта, ТолькоОсновнаяКонфигурация);
	ИначеЕсли ТипСервиса = "WebServices" Тогда
		Возврат ОперацияWebСервисаСуществует(ПолноеИмяЭндпоинта, ТолькоОсновнаяКонфигурация);
	Иначе
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция МетодHTTPСервисаСуществует(ПолноеИмяЭндпоинта, ТолькоОсновнаяКонфигурация = Истина)
	Попытка
		Сервисы = Метаданные.HTTPСервисы;
	Исключение
		Возврат Ложь;
	КонецПопытки;

	Для Каждого СервисМД Из Сервисы Цикл
		Шаблоны = ЗначениеПервогоСвойстваОбъектаМД(СервисМД, ИменаСвойств("ШаблоныURL", "URLTemplates"));
		Если Шаблоны = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого ШаблонМД Из Шаблоны Цикл
			Методы = ЗначениеПервогоСвойстваОбъектаМД(ШаблонМД, ИменаСвойств("Методы", "Methods"));
			Если Методы = Неопределено Тогда
				Продолжить;
			КонецЕсли;

			Для Каждого МетодМД Из Методы Цикл
				Если ПолноеИмяМетодаHTTPСервиса(СервисМД, ШаблонМД, МетодМД) = ПолноеИмяЭндпоинта Тогда
					Если ТолькоОсновнаяКонфигурация
						И (НЕ ЭтоОбъектОсновнойКонфигурации(СервисМД)
							ИЛИ НЕ ЭтоОбъектОсновнойКонфигурации(ШаблонМД)
							ИЛИ НЕ ЭтоОбъектОсновнойКонфигурации(МетодМД)) Тогда
						Возврат Ложь;
					КонецЕсли;
					Возврат Истина;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	Возврат Ложь;
КонецФункции

Функция ОперацияWebСервисаСуществует(ПолноеИмяЭндпоинта, ТолькоОсновнаяКонфигурация = Истина)
	Попытка
		Сервисы = Метаданные.WebСервисы;
	Исключение
		Возврат Ложь;
	КонецПопытки;

	Для Каждого СервисМД Из Сервисы Цикл
		Операции = ЗначениеПервогоСвойстваОбъектаМД(СервисМД, ИменаСвойств("Операции", "Operations"));
		Если Операции = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого ОперацияМД Из Операции Цикл
			Если ПолноеИмяОперацииWebСервиса(СервисМД, ОперацияМД) = ПолноеИмяЭндпоинта Тогда
				Если ТолькоОсновнаяКонфигурация
					И (НЕ ЭтоОбъектОсновнойКонфигурации(СервисМД)
						ИЛИ НЕ ЭтоОбъектОсновнойКонфигурации(ОперацияМД)) Тогда
					Возврат Ложь;
				КонецЕсли;
				Возврат Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	Возврат Ложь;
КонецФункции

Функция ТипИнтеграционногоСервисаПоПолномуИмени(ПолноеИмяСервиса)
	Части = СтрРазделить(ПолноеИмяСервиса, ".");
	Если Части.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если Части[0] = "HTTPService" Тогда
		Возврат "HTTPServices";
	ИначеЕсли Части[0] = "WebService" Тогда
		Возврат "WebServices";
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

Функция ВидLineageРазрешен(ФильтрВидовСвязей, ВидСвязи)
	Возврат ФильтрВидовСвязей.Количество() = 0
		ИЛИ ФильтрВидовСвязей.Получить(ВидСвязи) <> Неопределено;
КонецФункции

Процедура СобратьLineageВводаНаОсновании(Результат, ФильтрОбъектов, ФильтрВидовСвязей)

	Если НЕ ВидLineageРазрешен(ФильтрВидовСвязей, "basis") Тогда
		Возврат;
	КонецЕсли;

	ИменаСвойств = Новый Массив;
	ИменаСвойств.Добавить("ВводНаОсновании");
	ИменаСвойств.Добавить("ВводитсяНаОсновании");
	ИменаСвойств.Добавить("Основания");

	Для Каждого ДокументМД Из Метаданные.Документы Цикл
		Если НЕ ЭтоОбъектОсновнойКонфигурации(ДокументМД) Тогда
			Продолжить;
		КонецЕсли;

		Основания = ЗначениеПервогоСвойстваОбъектаМД(ДокументМД, ИменаСвойств);
		Если Основания = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого Основание Из Основания Цикл
			ПолноеИмяОснования = ПолноеИмяЗначенияМетаданных(Основание);
			Если ПолноеИмяОснования = Неопределено Тогда
				Продолжить;
			КонецЕсли;

			Детали = Новый Структура;
			Детали.Вставить("basis_object_full_name", КаноническоеПолноеИмяИзПолногоИмени(ПолноеИмяОснования));
			Детали.Вставить("document_full_name", КаноническоеПолноеИмяОбъекта(ДокументМД));

			Описание = "Документ " + ДокументМД.Имя
				+ " может быть введён на основании " + ПолноеИмяОснования + ".";
			ДобавитьLineageСвязь(
				Результат,
				ФильтрОбъектов,
				ФильтрВидовСвязей,
				ПолноеИмяОснования,
				КаноническоеПолноеИмяОбъекта(ДокументМД),
				"basis",
				"metadata",
				"high",
				Описание,
				Детали
			);
		КонецЦикла;

	КонецЦикла;

КонецПроцедуры

Процедура СобратьLineageДвиженийРегистров(Результат, ФильтрОбъектов, ФильтрВидовСвязей)

	Если НЕ ВидLineageРазрешен(ФильтрВидовСвязей, "register_movement") Тогда
		Возврат;
	КонецЕсли;

	ИменаСвойств = Новый Массив;
	ИменаСвойств.Добавить("Движения");
	ИменаСвойств.Добавить("ДвиженияДокумента");

	Для Каждого ДокументМД Из Метаданные.Документы Цикл
		Если НЕ ЭтоОбъектОсновнойКонфигурации(ДокументМД) Тогда
			Продолжить;
		КонецЕсли;

		Движения = ЗначениеПервогоСвойстваОбъектаМД(ДокументМД, ИменаСвойств);
		Если Движения = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого Движение Из Движения Цикл
			Если НЕ ЭтоОбъектОсновнойКонфигурации(Движение) Тогда
				Продолжить;
			КонецЕсли;

			ПолноеИмяРегистра = ПолноеИмяЗначенияМетаданных(Движение);
			Если ПолноеИмяРегистра = Неопределено Тогда
				Регистратор = ЗначениеПервогоСвойстваОбъектаМД(Движение, ИменаСвойствРегистраДвижения());
				ПолноеИмяРегистра = ПолноеИмяЗначенияМетаданных(Регистратор);
			КонецЕсли;

			Если ПолноеИмяРегистра = Неопределено Тогда
				Продолжить;
			КонецЕсли;

			ОписаниеРегистра = ОписаниеОбъектаПоПолномуИмени(ПолноеИмяРегистра);
			Если ОписаниеРегистра = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			Если НЕ ЭтоРегистрМетаданных(ОписаниеРегистра.object_type) Тогда
				Продолжить;
			КонецЕсли;

			Детали = Новый Структура;
			Детали.Вставить("document_full_name", КаноническоеПолноеИмяОбъекта(ДокументМД));
			Детали.Вставить("register_full_name", КаноническоеПолноеИмяИзПолногоИмени(ПолноеИмяРегистра));

			Описание = "Документ " + ДокументМД.Имя
				+ " делает движения по регистру " + ОписаниеРегистра.name + ".";
			ДобавитьLineageСвязь(
				Результат,
				ФильтрОбъектов,
				ФильтрВидовСвязей,
				КаноническоеПолноеИмяОбъекта(ДокументМД),
				ПолноеИмяРегистра,
				"register_movement",
				"metadata",
				"high",
				Описание,
				Детали
			);
		КонецЦикла;

	КонецЦикла;

КонецПроцедуры

Функция ИменаСвойствРегистраДвижения()
	ИменаСвойств = Новый Массив;
	ИменаСвойств.Добавить("Регистр");
	ИменаСвойств.Добавить("ОбъектМетаданных");
	ИменаСвойств.Добавить("Объект");
	Возврат ИменаСвойств;
КонецФункции

Процедура СобратьLineageКритериевОтбора(Результат, ФильтрОбъектов, ФильтрВидовСвязей)

	Если НЕ ВидLineageРазрешен(ФильтрВидовСвязей, "selection_criterion") Тогда
		Возврат;
	КонецЕсли;

	Попытка
		Критерии = Метаданные.КритерииОтбора;
	Исключение
		Возврат;
	КонецПопытки;

	Для Каждого КритерийМД Из Критерии Цикл
		Если НЕ ЭтоОбъектОсновнойКонфигурации(КритерийМД) Тогда
			Продолжить;
		КонецЕсли;

		ТипыКритерия = ЗначениеСвойстваОбъектаМД(КритерийМД, "Тип");
		ПолнИменаИсточников = ПолныеИменаИзОписанияТипов(ТипыКритерия);
		Если ПолнИменаИсточников.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;

		Состав = ЗначениеСвойстваОбъектаМД(КритерийМД, "Состав");
		Если Состав = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого ЭлементСостава Из Состав Цикл
			Если НЕ ЭтоОбъектОсновнойКонфигурации(ЭлементСостава) Тогда
				Продолжить;
			КонецЕсли;

			ПолноеИмяПолучателя = ПолноеИмяПолучателяКритерияОтбора(ЭлементСостава);
			Если ПолноеИмяПолучателя = Неопределено Тогда
				Продолжить;
			КонецЕсли;

			Для Каждого ПолноеИмяИсточника Из ПолнИменаИсточников Цикл
				Детали = Новый Структура;
				Детали.Вставить("criterion_name", КритерийМД.Имя);
				Детали.Вставить("criterion_full_name", КритерийМД.ПолноеИмя());

				Описание = "Критерий отбора " + КритерийМД.Имя
					+ " связывает " + ПолноеИмяИсточника
					+ " с " + ПолноеИмяПолучателя + ".";
				ДобавитьLineageСвязь(
					Результат,
					ФильтрОбъектов,
					ФильтрВидовСвязей,
					ПолноеИмяИсточника,
					ПолноеИмяПолучателя,
					"selection_criterion",
					"metadata",
					"low",
					Описание,
					Детали
				);
			КонецЦикла;
		КонецЦикла;

	КонецЦикла;

КонецПроцедуры

Процедура СобратьLineageРучныхСвязей(Результат, ФильтрОбъектов, ФильтрВидовСвязей)

	Если НЕ ВидLineageРазрешен(ФильтрВидовСвязей, "manual_dataset_flow") Тогда
		Возврат;
	КонецЕсли;

	РучныеСвязи = Новый Массив;
	Контекст = Новый Структура;
	Контекст.Вставить("filter_objects", ФильтрОбъектов);
	Контекст.Вставить("filter_kinds", ФильтрВидовСвязей);

	Попытка
		mds_ManualLineage.ДополнитьLineage(РучныеСвязи, Контекст);
	Исключение
		ВызватьИсключение "Ошибка получения мануального lineage: "
			+ ОписаниеОшибки();
	КонецПопытки;

	Для Каждого РучноеПравило Из РучныеСвязи Цикл
		ДобавитьРучнуюLineageСвязь(
			Результат,
			ФильтрОбъектов,
			ФильтрВидовСвязей,
			РучноеПравило
		);
	КонецЦикла;

КонецПроцедуры

Процедура ДобавитьРучнуюLineageСвязь(Результат, ФильтрОбъектов, ФильтрВидовСвязей, РучноеПравило)

	ВидСвязи = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("ВидСвязи", "kind"), "manual_dataset_flow");
	Если ВидСвязи <> "manual_dataset_flow" Тогда
		ВызватьИсключение "Неподдерживаемый вид мануального lineage: " + ВидСвязи;
	КонецЕсли;

	ОбъектИсточник = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("ОбъектИсточник", "upstream"), Неопределено);
	ОбъектПриемник = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("ОбъектПриемник", "downstream"), Неопределено);

	Если ОбъектИсточник = Неопределено Тогда
		ВызватьИсключение "Manual lineage rule не содержит ОбъектИсточник.";
	КонецЕсли;
	Если ОбъектПриемник = Неопределено Тогда
		ВызватьИсключение "Manual lineage rule не содержит ОбъектПриемник.";
	КонецЕсли;
	Если ЗначениеМетаданныхРасширенияКонфигурации(ОбъектИсточник)
		ИЛИ ЗначениеМетаданныхРасширенияКонфигурации(ОбъектПриемник) Тогда
		Возврат;
	КонецЕсли;

	ПолноеИмяUpstream = ПолноеИмяЗначенияМетаданных(ОбъектИсточник);
	ПолноеИмяDownstream = ПолноеИмяЗначенияМетаданных(ОбъектПриемник);
	Если ПолноеИмяUpstream = Неопределено Тогда
		ВызватьИсключение "Не удалось определить upstream объект manual lineage.";
	КонецЕсли;
	Если ПолноеИмяDownstream = Неопределено Тогда
		ВызватьИсключение "Не удалось определить downstream объект manual lineage.";
	КонецЕсли;
	ПроверитьОбъектManualLineage(ПолноеИмяUpstream, "upstream");
	ПроверитьОбъектManualLineage(ПолноеИмяDownstream, "downstream");

	Источник = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("ИсточникСвязи", "source"), "manual");
	Уверенность = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("Уверенность", "confidence"), "high");
	ПроверитьИсточникManualLineage(Источник);
	ПроверитьУверенностьManualLineage(Уверенность);

	Описание = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("Описание", "description"), Неопределено);
	Детали = ЗначениеСвойстваПравилаLineage(РучноеПравило, ИменаСвойств("Детали", "details"), Неопределено);

	ДобавитьLineageСвязь(
		Результат,
		ФильтрОбъектов,
		ФильтрВидовСвязей,
		ПолноеИмяUpstream,
		ПолноеИмяDownstream,
		ВидСвязи,
		Источник,
		Уверенность,
		Описание,
		Детали
	);

КонецПроцедуры

Функция ИменаСвойств(ИмяСвойства1, ИмяСвойства2 = Неопределено)
	Результат = Новый Массив;
	Результат.Добавить(ИмяСвойства1);
	Если ИмяСвойства2 <> Неопределено Тогда
		Результат.Добавить(ИмяСвойства2);
	КонецЕсли;
	Возврат Результат;
КонецФункции

Функция ЗначениеСвойстваПравилаLineage(Правило, ИменаСвойствПравила, ЗначениеПоУмолчанию)
	Для Каждого ИмяСвойства Из ИменаСвойствПравила Цикл
		Значение = Неопределено;
		Попытка
			Если Правило.Свойство(ИмяСвойства, Значение) Тогда
				Возврат Значение;
			КонецЕсли;
		Исключение
			Значение = Неопределено;
		КонецПопытки;

		Попытка
			Возврат Правило[ИмяСвойства];
		Исключение
			Продолжить;
		КонецПопытки;
	КонецЦикла;

	Возврат ЗначениеПоУмолчанию;
КонецФункции

Процедура ПроверитьОбъектManualLineage(ПолноеИмя, РольОбъекта)

	Описание = ОписаниеОбъектаПоПолномуИмени(ПолноеИмя);
	Если Описание = Неопределено Тогда
		ВызватьИсключение "Manual lineage rule содержит некорректный "
			+ РольОбъекта + " объект: " + ПолноеИмя;
	КонецЕсли;

	ОбъектМД = НайтиОбъектМетаданных(Описание.object_type, Описание.name);
	Если ОбъектМД = Неопределено Тогда
		ВызватьИсключение "Manual lineage rule ссылается на несуществующий "
			+ РольОбъекта + " объект: " + ПолноеИмя;
	КонецЕсли;

КонецПроцедуры

Процедура ПроверитьИсточникManualLineage(Источник)

	Если Источник = "metadata"
		ИЛИ Источник = "static_code"
		ИЛИ Источник = "runtime"
		ИЛИ Источник = "manual" Тогда
		Возврат;
	КонецЕсли;

	ВызватьИсключение "Неподдерживаемый источник мануального lineage: " + Строка(Источник);

КонецПроцедуры

Процедура ПроверитьУверенностьManualLineage(Уверенность)

	Если Уверенность = "low"
		ИЛИ Уверенность = "medium"
		ИЛИ Уверенность = "high" Тогда
		Возврат;
	КонецЕсли;

	ВызватьИсключение "Неподдерживаемая степень уверенности манулального lineage: " + Строка(Уверенность);

КонецПроцедуры

Функция ПолноеИмяПолучателяКритерияОтбора(ЭлементСостава)
	ИменаСвойств = Новый Массив;
	ИменаСвойств.Добавить("Объект");
	ИменаСвойств.Добавить("ОбъектМетаданных");
	ИменаСвойств.Добавить("Владелец");
	ИменаСвойств.Добавить("Родитель");

	Значение = ЗначениеПервогоСвойстваОбъектаМД(ЭлементСостава, ИменаСвойств);
	Возврат ПолноеИмяЗначенияМетаданных(Значение);
КонецФункции

Функция ЗначениеПервогоСвойстваОбъектаМД(ОбъектМД, ИменаСвойств)
	Для Каждого ИмяСвойства Из ИменаСвойств Цикл
		Значение = ЗначениеСвойстваОбъектаМД(ОбъектМД, ИмяСвойства);
		Если Значение <> Неопределено Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

Функция ПолныеИменаИзОписанияТипов(ОписаниеТипов)
	Результат = Новый Массив;
	Если ОписаниеТипов = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;

	Попытка
		Для Каждого ТекТип Из ОписаниеТипов.Типы() Цикл
			Если ИмяПримитивногоТипа(ТекТип) <> Неопределено Тогда
				Продолжить;
			КонецЕсли;

			ОбъектМДТипа = Метаданные.НайтиПоТипу(ТекТип);
			Если ОбъектМДТипа <> Неопределено Тогда
				Если НЕ ЭтоОбъектОсновнойКонфигурации(ОбъектМДТипа) Тогда
					Продолжить;
				КонецЕсли;
				Результат.Добавить(КаноническоеПолноеИмяОбъекта(ОбъектМДТипа));
			КонецЕсли;
		КонецЦикла;
	Исключение
		ПолноеИмя = ПолноеИмяЗначенияМетаданных(ОписаниеТипов);
		Если ПолноеИмя <> Неопределено Тогда
			Результат.Добавить(ПолноеИмя);
		КонецЕсли;
	КонецПопытки;

	Возврат Результат;
КонецФункции

Функция ПолноеИмяЗначенияМетаданных(Значение)
	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		КаноническоеПолноеИмя = КаноническоеПолноеИмяИзПолногоИмени(Значение);
		ОбъектМД = ОбъектМетаданныхПоПолномуИмениВключаяРасширения(КаноническоеПолноеИмя);
		Если ОбъектМД <> Неопределено
			И НЕ ЭтоОбъектОсновнойКонфигурации(ОбъектМД) Тогда
			Возврат Неопределено;
		КонецЕсли;
		Возврат КаноническоеПолноеИмя;
	КонецЕсли;

	Если НЕ ЭтоОбъектОсновнойКонфигурации(Значение) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Попытка
		Возврат КаноническоеПолноеИмяОбъекта(Значение);
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

Функция ОписаниеОбъектаПоПолномуИмени(ПолноеИмя)
	Если ПолноеИмя = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если ПустаяСтрока(ПолноеИмя) Тогда
		Возврат Неопределено;
	КонецЕсли;

	КаноническоеПолноеИмя = КаноническоеПолноеИмяИзПолногоИмени(ПолноеИмя);
	Части = СтрРазделить(КаноническоеПолноеИмя, ".");
	Если Части.Количество() < 2 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Описание = Новый Структура;
	Описание.Вставить("object_type", ИмяТипаОбъектаПоПолномуИмени(Части[0]));
	Описание.Вставить("name", Части[1]);
	Описание.Вставить("full_name", КаноническоеПолноеИмя);
	Возврат Описание;
КонецФункции

Процедура ДобавитьLineageСвязь(
	Результат,
	ФильтрОбъектов,
	ФильтрВидовСвязей,
	ПолноеИмяUpstream,
	ПолноеИмяDownstream,
	ВидСвязи,
	Источник,
	Уверенность,
	Описание,
	Детали
)
	Если НЕ ВидLineageРазрешен(ФильтрВидовСвязей, ВидСвязи) Тогда
		Возврат;
	КонецЕсли;

	ПолноеИмяUpstream = КаноническоеПолноеИмяИзПолногоИмени(ПолноеИмяUpstream);
	ПолноеИмяDownstream = КаноническоеПолноеИмяИзПолногоИмени(ПолноеИмяDownstream);
	Если НЕ ЭтоПолноеИмяОбъектаОсновнойКонфигурации(ПолноеИмяUpstream)
		ИЛИ НЕ ЭтоПолноеИмяОбъектаОсновнойКонфигурации(ПолноеИмяDownstream) Тогда
		Возврат;
	КонецЕсли;

	Если ФильтрОбъектов.Количество() > 0 Тогда
		Если ФильтрОбъектов.Получить(ПолноеИмяUpstream) = Неопределено Тогда
			Возврат;
		КонецЕсли;
		Если ФильтрОбъектов.Получить(ПолноеИмяDownstream) = Неопределено Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;

	Upstream = ОписаниеОбъектаПоПолномуИмени(ПолноеИмяUpstream);
	Downstream = ОписаниеОбъектаПоПолномуИмени(ПолноеИмяDownstream);
	Если Upstream = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Если Downstream = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Связь = Новый Структура;
	Связь.Вставить("upstream_object_type", Upstream.object_type);
	Связь.Вставить("upstream_name", Upstream.name);
	Связь.Вставить("downstream_object_type", Downstream.object_type);
	Связь.Вставить("downstream_name", Downstream.name);
	Связь.Вставить("kind", ВидСвязи);
	Связь.Вставить("source", Источник);
	Связь.Вставить("confidence", Уверенность);

	Если Описание <> Неопределено Тогда
		Если НЕ ПустаяСтрока(Описание) Тогда
			Связь.Вставить("description", Описание);
		КонецЕсли;
	КонецЕсли;
	Если Детали <> Неопределено Тогда
		Если Детали.Количество() > 0 Тогда
			Связь.Вставить("details", Детали);
		КонецЕсли;
	КонецЕсли;

	Результат.Добавить(Связь);
КонецПроцедуры

Функция ДедублироватьLineage(Связи)
	Ключи = Новый Соответствие;
	Результат = Новый Массив;
	Для Каждого Связь Из Связи Цикл
		Ключ = Связь.upstream_object_type + "|" + Связь.upstream_name + "|"
			+ Связь.downstream_object_type + "|" + Связь.downstream_name + "|"
			+ Связь.kind;
		Если Ключи.Получить(Ключ) = Неопределено Тогда
			Ключи.Вставить(Ключ, Истина);
			Результат.Добавить(Связь);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ИмяПримитивногоТипа(ТекТип)
	Если ТекТип = Тип("Строка") Тогда
		Возврат "Строка";
	ИначеЕсли ТекТип = Тип("Число") Тогда
		Возврат "Число";
	ИначеЕсли ТекТип = Тип("Дата") Тогда
		Возврат "Дата";
	ИначеЕсли ТекТип = Тип("Булево") Тогда
		Возврат "Булево";
	ИначеЕсли ТекТип = Тип("УникальныйИдентификатор") Тогда
		Возврат "УникальныйИдентификатор";
	ИначеЕсли ТекТип = Тип("ХранилищеЗначения") Тогда
		Возврат "ХранилищеЗначения";
	Иначе
		Возврат Неопределено;
	КонецЕсли;
КонецФункции

#КонецОбласти

#Область ПоискОбъектоМетаданных

Функция НайтиОбъектМетаданных(ИмяТипа, ИмяОбъекта)
	ОбъектМД = НайтиОбъектМетаданныхВключаяРасширения(ИмяТипа, ИмяОбъекта);
	Если НЕ ЭтоОбъектОсновнойКонфигурации(ОбъектМД) Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат ОбъектМД;
КонецФункции

Функция НайтиОбъектМетаданныхВключаяРасширения(ИмяТипа, ИмяОбъекта)
	ТипыОбъектов = ПоддерживаемыеТипыОбъектов();
	КоллекцияМетаданных = ТипыОбъектов.Получить(ИмяТипа);
	Если КоллекцияМетаданных = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат КоллекцияМетаданных.Найти(ИмяОбъекта);
КонецФункции

Функция ОбъектМетаданныхПоПолномуИмениВключаяРасширения(ПолноеИмя)
	Описание = ОписаниеОбъектаПоПолномуИмени(ПолноеИмя);
	Если Описание = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат НайтиОбъектМетаданныхВключаяРасширения(Описание.object_type, Описание.name);
КонецФункции

Функция ЗначениеМетаданныхРасширенияКонфигурации(Значение)
	Если Значение = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Если ТипЗнч(Значение) = Тип("Строка") Тогда
		ОбъектМД = ОбъектМетаданныхПоПолномуИмениВключаяРасширения(Значение);
		Возврат ОбъектМД <> Неопределено
			И НЕ ЭтоОбъектОсновнойКонфигурации(ОбъектМД);
	КонецЕсли;

	Возврат НЕ ЭтоОбъектОсновнойКонфигурации(Значение);
КонецФункции

Функция ПоддерживаемыеТипыОбъектов()
	Результат = Новый Соответствие;
	Результат.Вставить("Constants",                   Метаданные.Константы);
	Результат.Вставить("Catalogs",                    Метаданные.Справочники);
	Результат.Вставить("Documents",                   Метаданные.Документы);
	Результат.Вставить("ChartsOfCharacteristicTypes", Метаданные.ПланыВидовХарактеристик);
	Результат.Вставить("ChartsOfAccounts",            Метаданные.ПланыСчетов);
	Результат.Вставить("ChartsOfCalculationTypes",    Метаданные.ПланыВидовРасчета);
	Результат.Вставить("InformationRegisters",        Метаданные.РегистрыСведений);
	Результат.Вставить("AccumulationRegisters",       Метаданные.РегистрыНакопления);
	Результат.Вставить("AccountingRegisters",         Метаданные.РегистрыБухгалтерии);
	Результат.Вставить("CalculationRegisters",        Метаданные.РегистрыРасчета);
	Результат.Вставить("Enums",                       Метаданные.Перечисления);
	Возврат Результат;
КонецФункции

Функция ЭтоРегистрМетаданных(ИмяТипа)
	Возврат ИмяТипа = "InformationRegisters"
		ИЛИ ИмяТипа = "AccumulationRegisters"
		ИЛИ ИмяТипа = "AccountingRegisters"
		ИЛИ ИмяТипа = "CalculationRegisters";
КонецФункции

#КонецОбласти

#Область Прочее

Функция ПодпутьПослеПрефикса(ОтносительныйURL, Префикс)
	Подпуть = Сред(ОтносительныйURL, СтрДлина(Префикс) + 1);
	Пока СтрНачинаетсяС(Подпуть, "/") Цикл
		Подпуть = Сред(Подпуть, 2);
	КонецЦикла;
	Возврат Подпуть;
КонецФункции

Функция ОтветJSON(КодСостояния, Данные)
	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");

	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, Данные);
	Ответ.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть());

	Возврат Ответ;
КонецФункции

Функция ОтветОшибки(КодСостояния, Сообщение)
	Данные = Новый Структура;
	Данные.Вставить("error", Сообщение);
	Возврат ОтветJSON(КодСостояния, Данные);
КонецФункции

#КонецОбласти

#Область МаппингОбъектов

Функция СписокМаппингаБД(Запрос)
	ФильтрТипов = Новый Массив;
	ТипыСтрока = Запрос.ПараметрыЗапроса.Получить("types");
	Если ТипыСтрока <> Неопределено И НЕ ПустаяСтрока(ТипыСтрока) Тогда
		Для Каждого ЭлементТипа Из СтрРазделить(ТипыСтрока, ",") Цикл
			ФильтрТипов.Добавить(СокрЛП(ЭлементТипа));
		КонецЦикла;
	КонецЕсли;

	Результат = Новый Массив;
	ТипыОбъектов = ПоддерживаемыеТипыОбъектов();

	Для Каждого КлючЗначение Из ТипыОбъектов Цикл
		ИмяТипа = КлючЗначение.Ключ;
		КоллекцияМетаданных = КлючЗначение.Значение;

		Если ФильтрТипов.Количество() > 0 И ФильтрТипов.Найти(ИмяТипа) = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого ОбъектМД Из КоллекцияМетаданных Цикл
			Если НЕ ЭтоОбъектОсновнойКонфигурации(ОбъектМД) Тогда
				Продолжить;
			КонецЕсли;

			КраткийМаппинг = Новый Структура;
			КраткийМаппинг.Вставить("object_type", ИмяТипа);
			КраткийМаппинг.Вставить("object_name", ОбъектМД.Имя);
			Результат.Добавить(КраткийМаппинг);
		КонецЦикла;
	КонецЦикла;

	Возврат ОтветJSON(200, Результат);
КонецФункции

Функция МаппингОбъектаБД(ИмяТипа, ИмяОбъекта)
	ОбъектМД = НайтиОбъектМетаданных(ИмяТипа, ИмяОбъекта);
	Если ОбъектМД = Неопределено Тогда
		Возврат ОтветОшибки(404, "Object not found");
	КонецЕсли;

	Маппинг = СобратьМаппингБДПолный(ОбъектМД, ИмяТипа);
	Возврат ОтветJSON(200, Маппинг);
КонецФункции

Функция ТабличнаяЧастьМетаданных(ОбъектМД, ИмяТабличнойЧасти)
	Попытка
		ТабЧасти = ОбъектМД.ТабличныеЧасти;
	Исключение
		Возврат Неопределено;
	КонецПопытки;

	Для Каждого ТабЧасть Из ТабЧасти Цикл
		Если ТабЧасть.Имя = ИмяТабличнойЧасти Тогда
			Возврат ТабЧасть;
		КонецЕсли;
	КонецЦикла;

	Возврат Неопределено;
КонецФункции

Функция ПодчиненныйОбъектМетаданныхПоИмени(ВладелецМД, ИмяПодчиненного)
	ИменаКоллекций = Новый Массив;
	ИменаКоллекций.Добавить("СтандартныеРеквизиты");
	ИменаКоллекций.Добавить("Реквизиты");
	ИменаКоллекций.Добавить("Измерения");
	ИменаКоллекций.Добавить("Ресурсы");

	Для Каждого ИмяКоллекции Из ИменаКоллекций Цикл
		Коллекция = ЗначениеСвойстваОбъектаМД(ВладелецМД, ИмяКоллекции);
		Если Коллекция = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Для Каждого ПодчиненныйМД Из Коллекция Цикл
			Если ПодчиненныйМД.Имя = ИмяПодчиненного Тогда
				Возврат ПодчиненныйМД;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;

	Возврат Неопределено;
КонецФункции

Функция ОбъектМетаданныхПоляХранения(ОбъектМД, ИмяТабличнойЧасти, ИмяПоля)
	Если ИмяТабличнойЧасти <> Неопределено Тогда
		ТабЧасть = ТабличнаяЧастьМетаданных(ОбъектМД, ИмяТабличнойЧасти);
		Если ТабЧасть = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
		Возврат ПодчиненныйОбъектМетаданныхПоИмени(ТабЧасть, ИмяПоля);
	КонецЕсли;

	Возврат ПодчиненныйОбъектМетаданныхПоИмени(ОбъектМД, ИмяПоля);
КонецФункции

Функция СобратьМаппингБДПолный(ОбъектМД, ИмяТипа)

	Результат = Новый Структура;
	Результат.Вставить("object_type", ИмяТипа);
	Результат.Вставить("name", ОбъектМД.Имя);

	Таблицы = Новый Массив;

	ОбъектыМетаданных = Новый Массив;
	ОбъектыМетаданных.Добавить(ОбъектМД);
	СтруктураХранения = ПолучитьСтруктуруХраненияБазыДанных(ОбъектыМетаданных, Истина);

	ПоддерживаемыеНазначенияТаблиц = ПоддерживаемыеНазначенияТаблицБазыДанных();

	Для Каждого ТаблицаХранения Из СтруктураХранения Цикл

		// Описание таблицы

		ЗаписьТаблицы = Новый Структура;
		ЗаписьТаблицы.Вставить("db_table_name", ТаблицаХранения.ИмяТаблицыХранения);

		НазначениеТаблицы = НазначениеТаблицыНаАнглийском(ТаблицаХранения.Назначение);
		Если НазначениеТаблицы = Неопределено
			ИЛИ ПоддерживаемыеНазначенияТаблиц.Получить(НазначениеТаблицы) = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		ИмяТабличнойЧасти = Неопределено;
		Если НазначениеТаблицы = "TabularSection" Тогда
			ЧастиИмени = СтрРазделить(ТаблицаХранения.ИмяТаблицы, ".");
			ИмяТабличнойЧасти = ЧастиИмени[ЧастиИмени.ВГраница()];
			ТабЧасть = ТабличнаяЧастьМетаданных(ОбъектМД, ИмяТабличнойЧасти);
			Если ТабЧасть = Неопределено
				ИЛИ НЕ ЭтоОбъектОсновнойКонфигурации(ТабЧасть) Тогда
				Продолжить;
			КонецЕсли;
			ЗаписьТаблицы.Вставить("tabular_section_name", ИмяТабличнойЧасти);
		КонецЕсли;

		ЗаписьТаблицы.Вставить("purpose", НазначениеТаблицы);

		// Описание полей и колонок БД

		КешОписанийПолей = Новый Соответствие;

		ОписаниеКолонокТаблицы = Новый Массив;
		Для Каждого ПолеХранения Из ТаблицаХранения.Поля Цикл
			ПолеМД = ОбъектМетаданныхПоляХранения(
				ОбъектМД,
				ИмяТабличнойЧасти,
				ПолеХранения.ИмяПоля
			);
			Если ПолеМД <> Неопределено
				И НЕ ЭтоОбъектОсновнойКонфигурации(ПолеМД) Тогда
				Продолжить;
			КонецЕсли;

			// Поле 1С

			ОписаниеПоля = КешОписанийПолей.Получить(ПолеХранения.ИмяПоля);
			Если ОписаниеПоля = Неопределено Тогда
				ОписаниеПоля = Новый Структура;
				ОписаниеПоля.Вставить("attribute_name", ПолеХранения.ИмяПоля);
				ОписаниеПоля.Вставить("db_columns", Новый Массив);
				ОписаниеКолонокТаблицы.Добавить(ОписаниеПоля);
				КешОписанийПолей.Вставить(ПолеХранения.ИмяПоля, ОписаниеПоля);
			КонецЕсли;

			// Колонки БД

			ИмяПоляХранения = ПолеХранения.ИмяПоляХранения;
			ИмяПоляХраненияНРег = НРег(ИмяПоляХранения);
			КолонкиБД = ОписаниеПоля.db_columns;

			ОписаниеКолонкиБД = Новый Структура;
			ОписаниеКолонкиБД.Вставить("column_name", ИмяПоляХранения);

			НазначениеКолонкиБД = "";
			Если СтрЗаканчиваетсяНа(ИмяПоляХраненияНРег, "_type") Тогда
				НазначениеКолонкиБД = "type_discriminator";
			ИначеЕсли СтрЗаканчиваетсяНа(ИмяПоляХраненияНРег, "_rtref") Тогда
				НазначениеКолонкиБД = "reference_discriminator";
			ИначеЕсли СтрЗаканчиваетсяНа(ИмяПоляХраненияНРег, "rref") Тогда
				НазначениеКолонкиБД = "reference";
			Иначе
				НазначениеКолонкиБД = "value";
			КонецЕсли;
			ОписаниеКолонкиБД.Вставить("purpose", НазначениеКолонкиБД);

			КолонкиБД.Добавить(ОписаниеКолонкиБД);

		КонецЦикла;

		ЗаписьТаблицы.Вставить("columns", ОписаниеКолонокТаблицы);
		Таблицы.Добавить(ЗаписьТаблицы);
	КонецЦикла;

	Результат.Вставить("tables", Таблицы);
	Возврат Результат;

КонецФункции

Функция НазначениеТаблицыНаАнглийском(Назначение)

	Если ВариантВстроенногоЯзыкаКонфигурацииАнглийский() Тогда
		Возврат Назначение;
	Иначе
		Словарь = СловарьСоответствийНазначенийТаблицБазыДанных();
		НазначениеНаАнглийском = Словарь.Получить(Назначение);
		Если ЗначениеЗаполнено(НазначениеНаАнглийском) Тогда
			Возврат НазначениеНаАнглийском;
		Иначе
			Возврат Неопределено;
		КонецЕсли;
	КонецЕсли;

КонецФункции

